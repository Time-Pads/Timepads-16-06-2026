{% style %}
.mobile-navigation-bottom {
  background: white;
  color: black;
  position: fixed;
  bottom: 0;
  width: 100%;
  z-index: 9999;
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
}

.mobile-navigation-menu {
  display: flex;
  width: 95%;
  justify-content: space-between;
  align-items: center;
  position: relative;
  margin: auto;
}

.mobile-menu__link {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: black;
  text-decoration: none;
  font-size: 12px;
}

.mobile-menu__title {
  margin-top: 4px;
}

.mobile-center-cart {
  position: relative;
}

.cart-circle {
    background: white;
    box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
}

.cart-circle svg {
  fill: #fff;
  width: 30px;
  height: 30px;
}
.mobile-navigation-menu svg{
    width: 20px;
    height: 17px;
}
.mobile-center-cart .header__mobile__button{
    position: absolute;
    top: -31px;
    left: -32px;
}
@media only screen and (min-width: 768px){
    .desktop-hide{
       display: none;
    }
}

.mobile-navigation-bottom {
  background: white;
  color: black;
  position: fixed;
  bottom: 0;
  width: 100%;
  z-index: 9999;
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  transition: transform 0.3s ease-in-out; /* Smooth slide animation */
}

.mobile-navigation-bottom{
    box-shadow: rgba(0, 0, 0, 0.25) 0px 54px 55px, rgba(0, 0, 0, 0.12) 0px -12px 30px, rgba(0, 0, 0, 0.12) 0px 4px 6px, rgba(0, 0, 0, 0.17) 0px 12px 13px, rgba(0, 0, 0, 0.09) 0px -3px 5px;
}

{% endstyle %}

<script>

let lastScrollTop = 0; // Store the last scroll position
  const bottomNav = document.querySelector(".mobile-navigation-bottom");

  window.addEventListener("scroll", function () {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;

    if (scrollTop > lastScrollTop) {
      // User is scrolling down - SHOW the navigation bar
      bottomNav.style.transform = "translateY(0)";
    } else {
      // User is scrolling up - HIDE the navigation bar
      bottomNav.style.transform = "translateY(100%)";
    }

    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop; // Prevent negative values
  });



  // Add event listener for the search icon click
  document.getElementById("search-icon").addEventListener("click", function () {
    const navElement = document.getElementById("header-menu");
    navElement.classList.toggle("drawer--visible");
    navElement.classList.toggle("display-none");
  });
</script>


