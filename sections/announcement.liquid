<!-- /sections/announcement.liquid -->
{%- if section.blocks.size > 0 -%}
  {%- assign font_size_class = 'accent-size-' | append: section.settings.text_size -%}
  {%- assign is_slider = false -%}
  {%- assign is_marquee = false -%}
  {%- if section.settings.layout == 'slider' -%}{%- assign is_slider = true -%}{%- endif -%}
  {%- if section.settings.layout == 'marquee' -%}{%- assign is_marquee = true -%}{%- endif -%}
  {%- assign bar_markup = '' -%}

  {%- for block in section.blocks -%}
    {%- assign show_bar = true -%}

    {%- comment -%} Target URL check {%- endcomment -%}
    {%- if block.settings.target_url_enabled or block.settings.target_referrer_enabled -%}
      {%- assign show_bar = false -%}
      {%- if block.settings.target_url_enabled and block.settings.target_url != blank -%}
        {%- if block.settings.target_url == request.path -%}{%- assign show_bar = true -%}{%- endif -%}
      {%- endif -%}
      {%- if block.settings.target_referrer_enabled and block.settings.target_referrer != blank -%}
        {%- assign show_bar = true -%}
      {%- endif -%}
    {%- endif -%}

    {%- if request.design_mode -%}{%- assign show_bar = true -%}{%- endif -%}

    {%- if show_bar -%}
      {%- comment -%} Build classes {%- endcomment -%}
      {%- assign classes = 'section-padding items-center' -%}

      {%- if block.settings.target_device_enabled -%}
        {%- if is_slider -%}
          {%- assign classes = classes | append: ' flex' -%}
        {%- elsif is_marquee -%}
          {%- if block.settings.target_device == 'desktop' -%}
            {%- assign classes = classes | append: ' hidden md:flex' -%}
          {%- else -%}
            {%- assign classes = classes | append: ' flex md:hidden' -%}
          {%- endif -%}
        {%- endif -%}
      {%- else -%}
        {%- assign classes = classes | append: ' flex' -%}
      {%- endif -%}

      {%- if is_slider -%}{%- assign classes = classes | append: ' text-center w-full' -%}{%- endif -%}
      {%- if is_marquee -%}{%- assign classes = classes | append: ' px-[--items-spacing]' -%}{%- endif -%}

      {%- comment -%} Target referrer attribute {%- endcomment -%}
      {%- assign target_referrer_attr = '' -%}
      {%- if block.settings.target_referrer_enabled and block.settings.target_referrer != blank -%}
        {%- assign target_referrer_attr = block.settings.target_referrer -%}
      {%- endif -%}

      {%- comment -%} Device attribute (slider only) {%- endcomment -%}
      {%- assign device_attr = '' -%}
      {%- if block.settings.target_device_enabled and is_slider -%}
        {%- assign device_attr = block.settings.target_device -%}
      {%- endif -%}

      {%- comment -%} Build block content {%- endcomment -%}
      {%- assign has_content = false -%}
      {%- if block.settings.message != blank or block.settings.text != blank -%}
        {%- assign has_content = true -%}
      {%- endif -%}
      {%- if block.type == 'icon_block' -%}{%- assign has_content = true -%}{%- endif -%}

      {%- if has_content -%}
        {%- capture bar_html -%}
          <div
            class="{{ classes }}"
            x-ref="{{ block.id }}"
            {%- if device_attr != '' -%} data-device="{{ device_attr }}"{%- endif -%}
            {%- if target_referrer_attr != '' -%} x-target-referrer="{{ target_referrer_attr }}"{%- endif -%}
            {%- if block.type == 'message' -%} data-cart-message-container{%- endif -%}
            {{ block.shopify_attributes }}
          >
            {%- if is_slider -%}
              <div class="w-full px-[--outer] text-[0] overflow-hidden" data-ticker-frame x-data="announcementTicker({ waitForSlider: true })">
                <div class="inline-flex items-center transition-opacity duration-500 ease-linear ticker--unloaded" data-ticker-scale>
                  <div class="rte--lock-font rte--lock-size px-r6 flex flex-row items-center {{ font_size_class }}" data-ticker-text>
            {%- endif -%}

            {%- case block.type -%}
              {%- when 'text' -%}
                {%- if block.settings.text != blank -%}{{ block.settings.text }}{%- endif -%}

              {%- when 'message' -%}
                {%- if block.settings.message != blank -%}
                  {%- render 'cart-shipping-message', message: block.settings.message, show_wheel: false, font_size_class: font_size_class -%}
                {%- endif -%}

              {%- when 'custom' -%}
                {%- if block.settings.text != blank -%}{{ block.settings.text }}{%- endif -%}

              {%- when 'icon_block' -%}
                {%- comment -%} Icon/image {%- endcomment -%}
                {%- if block.settings.icon_alt != blank -%}
                  {%- assign icon_img = block.settings.icon_alt -%}
                  {%- assign icon_w = block.settings.icon_alt_width | at_most: icon_img.width -%}
                  {%- assign icon_w2x = icon_w | times: 2 | at_most: icon_img.width -%}
                  {%- render 'image',
                    img_object: icon_img,
                    wh_ratio: icon_img.aspect_ratio,
                    width: icon_w,
                    srcset: icon_img | image_url: width: icon_w2x | append: ' 2x, ' | append: (icon_img | image_url: width: icon_w),
                    alt: icon_img.alt | default: shop.name,
                    cover: false,
                    wrapper_style: '--image-max-width:' | append: block.settings.icon_alt_width | append: 'px',
                    wrapper_class: 'mr-[0.5em] max-w-[--image-max-width]',
                    loading: 'eager'
                  -%}
                {%- else -%}
                  <div class="mr-[0.5em] {{ font_size_class }}" style="--ICON-STROKE-COLOR:{{ block.settings.icon_color }}">
                    {%- render 'icon-setting', filename: block.settings.icon_name -%}
                  </div>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte {{ font_size_class }}">{{ block.settings.text | replace: '|', '&nbsp;<span class="ml-[0.33em] pr-[0.33em] w-0 border-l border-current"></span>&nbsp;' }}</div>
                {%- endif -%}
            {%- endcase -%}

            {%- if is_slider -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endcapture -%}
        {%- assign bar_markup = bar_markup | append: bar_html -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if bar_markup != blank -%}
    <div
      class="announcement text-[--text] relative z-[5500] overflow-hidden body-color"
      style="--PT:{{ section.settings.padding_top }}px;--PB:{{ section.settings.padding_bottom }}px;--text:var(--COLOR-ANNOUNCEMENT-TEXT);--underline:calc(var(--font-{{ section.settings.text_size }}) * var(--FONT-ADJUST-ACCENT)); min-height: calc({{ section.settings.padding_top }}px + {{ section.settings.padding_bottom }}px + calc(var(--font-{{ section.settings.text_size }}, 14px) * 1.5));"
      data-announcement-bar
      data-section-id="{{ section.id }}"
      data-section-type="announcement"
      x-data="announcement()"
    >
      {%- if is_slider -%}
        <div
          class="{{ font_size_class }}"
          x-data="announcementSlider({{ section.settings.speed | times: 1000 }})"
          {%- if request.design_mode -%}
            @shopify:block:select="onBlockSelect"
            @shopify:block:deselect="onBlockDeselect"
            @shopify:section:unload="onUnload"
          {%- endif -%}
        >
          {{ bar_markup }}
        </div>
      {%- endif -%}

      {%- if is_marquee -%}
        <div style="--items-spacing:{{ section.settings.text_size | times: 4 }}px">
          <div class="flex justify-between items-center text-center w-full">
            <div
              class="w-full px-[--outer] text-[0] overflow-hidden"
              data-ticker-frame
              x-data="announcementTicker({ stopClone: true })"
              {%- if request.design_mode -%}
                @shopify:block:select="onBlockSelect"
                @shopify:block:deselect="onBlockDeselect"
              {%- endif -%}
            >
              <div class="inline-flex items-center transition-opacity duration-500 ease-linear ticker--unloaded" data-ticker-scale>
                <div class="rte--lock-font rte--lock-size flex flex-row items-center w-max {{ font_size_class }}" data-ticker-text>
                  {{ bar_markup }}
                </div>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 1,
      "max": 15,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "slider", "label": "Slider" },
        { "value": "marquee", "label": "Marquee" }
      ]
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Autoplay speed",
      "unit": "sec",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "paragraph",
      "content": "Note: the transparent header setting will hide announcements placed beneath a transparent header. For transparent header announcements, use the toolbar block of the header section."
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text announcement",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p><strong>Make an announcement</strong> | More info</p>"
        },
        { "type": "header", "content": "Target page" },
        { "id": "target_url_enabled", "type": "checkbox", "label": "Limit to specific page" },
        { "id": "target_url", "type": "url", "label": "Targeted page" },
        { "type": "header", "content": "Target referrer" },
        { "id": "target_referrer_enabled", "type": "checkbox", "label": "Limit to specific referrer path" },
        { "id": "target_referrer", "type": "text", "label": "Targeted referrer" },
        { "type": "header", "content": "Target device" },
        { "id": "target_device_enabled", "type": "checkbox", "label": "Limit to desktop or mobile" },
        {
          "type": "select",
          "id": "target_device",
          "label": "Device",
          "default": "mobile",
          "options": [
            { "value": "mobile", "label": "Only show on mobile" },
            { "value": "desktop", "label": "Only show on desktop" }
          ]
        }
      ]
    },
    {
      "type": "message",
      "name": "Free shipping message",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "message",
          "label": "Message",
          "info": "Use ||amount|| to display progress towards free shipping.",
          "default": "Spend ||amount|| more for free shipping"
        },
        { "type": "paragraph", "content": "Navigate to Theme settings > Cart > Free shipping message to set the amount." },
        { "type": "header", "content": "Target page" },
        { "id": "target_url_enabled", "type": "checkbox", "label": "Limit to specific page" },
        { "id": "target_url", "type": "url", "label": "Targeted page" },
        { "type": "header", "content": "Target referrer" },
        { "id": "target_referrer_enabled", "type": "checkbox", "label": "Limit to specific referrer path" },
        { "id": "target_referrer", "type": "text", "label": "Targeted referrer" },
        { "type": "header", "content": "Target device" },
        { "id": "target_device_enabled", "type": "checkbox", "label": "Limit to desktop or mobile" },
        {
          "type": "select",
          "id": "target_device",
          "label": "Device",
          "default": "mobile",
          "options": [
            { "value": "mobile", "label": "Only show on mobile" },
            { "value": "desktop", "label": "Only show on desktop" }
          ]
        }
      ]
    },
    {
      "type": "custom",
      "name": "Custom HTML",
      "settings": [
        {
          "type": "liquid",
          "id": "text",
          "label": "Text",
          "default": "<p>Custom HTML</p>"
        },
        { "type": "header", "content": "Target page" },
        { "id": "target_url_enabled", "type": "checkbox", "label": "Limit to specific page" },
        { "id": "target_url", "type": "url", "label": "Targeted page" },
        { "type": "header", "content": "Target referrer" },
        { "id": "target_referrer_enabled", "type": "checkbox", "label": "Limit to specific referrer path" },
        { "id": "target_referrer", "type": "text", "label": "Targeted referrer" },
        { "type": "header", "content": "Target device" },
        { "id": "target_device_enabled", "type": "checkbox", "label": "Limit to desktop or mobile" },
        {
          "type": "select",
          "id": "target_device",
