{% schema %}
{
  "name": "Multiple Videos",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Watch, Explore & Buy"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Multiple Videos",
      "category": "Media",
      "blocks": [
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}

<section class="multi-video-section" data-clarity-region="video-section">
  {% if section.settings.section_heading != blank %}
    <h2 class="multi-video-heading kicker-flourished center">{{ section.settings.section_heading }}</h2>
  {% endif %}

  <div class="swiper multi-video-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% if block.settings.video_url != blank %}
          <div class="swiper-slide video-wrapper" data-clarity-region="video-section">
           <video
  class="video-item"
  autoplay
  muted
  loop
  playsinline
  data-product-title="{{ block.settings.product.title }}"
  data-product-img="{{ block.settings.product.featured_image | img_url: 'master' }}"
  data-product-url="{{ block.settings.product.url }}"
>
  <source src="{{ block.settings.video_url }}" type="video/mp4">
  Your browser does not support the video tag.
</video>


            {% if block.settings.product != blank %}
              <a href="{{ block.settings.product.url }}">
                <div class="product-info">
                  <img src="{{ block.settings.product.featured_image | img_url: 'master' }}" alt="{{ block.settings.product.title }}" width="100" height="50">
                  <p>{{ block.settings.product.title }}</p>
                </div>
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const videos = document.querySelectorAll(".video-item");

    videos.forEach(video => {
      // For safety, ensure video is muted before autoplay
      video.muted = true;
      video.autoplay = true;
      video.playsInline = true;
      video.loop = true;

      // Try to play the video
      const playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.catch(error => {
          console.warn("Autoplay failed for video:", error);
        });
      }
    });
  });
</script>


<!-- Modal (optional) -->
<div id="video-modal" class="video-modal hidden">
  <div class="video-modal-content">
    <span class="video-modal-close">&times;</span>
    <video id="modal-video" controls autoplay playsinline></video>
    <div class="product-info" id="modal-product-info"></div>
  </div>
</div>

<!-- SwiperJS CDN -->  
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script defer src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!-- Lazy Load Videos Script -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const modal = document.getElementById("video-modal");
    const modalVideo = document.getElementById("modal-video");
    const modalProductInfo = document.getElementById("modal-product-info");
    const closeModal = document.querySelector(".video-modal-close");

    // Play video on slide when in view
    const lazyVideos = document.querySelectorAll('video.lazy-video');

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const video = entry.target;
          if (!video.src) {
            video.src = video.dataset.src;
            video.load();
          }
          observer.unobserve(video);
        }
      });
    }, { rootMargin: "200px" });

    lazyVideos.forEach(video => {
      observer.observe(video);

      // 👇 On click, open modal and play video
      video.addEventListener("click", function () {
        modal.classList.remove("hidden");

        modalVideo.src = video.dataset.src;
        modalVideo.load();
        modalVideo.play();

        // Update product info
        modalProductInfo.innerHTML = `
          <a href="${video.dataset.productUrl}" style="color: white;">
            <img src="${video.dataset.productImg}" width="80" height="80" style="border-radius:50%; margin-bottom: 10px;">
            <p>${video.dataset.productTitle}</p>
          </a>
        `;
      });
    });

    // Close modal and stop video
    closeModal.addEventListener("click", function () {
      modal.classList.add("hidden");
      modalVideo.pause();
      modalVideo.src = "";
      modalProductInfo.innerHTML = "";
    });

    // Optional: close modal on outside click
    modal.addEventListener("click", function (e) {
      if (e.target === modal) {
        modal.classList.add("hidden");
        modalVideo.pause();
        modalVideo.src = "";
        modalProductInfo.innerHTML = "";
      }
    });
  });
</script>


<!-- Styling -->
<style>
  .multi-video-section {
    padding: 40px 20px;
    background-color: #f8f8f8;
  }
.multi-video-heading.kicker-flourished.center{
  text-align: center;
  width: 100%;
  margin-bottom:0;
  margin-top:0;
}
  .multi-video-heading {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 30px;
  }

  .swiper {
    padding-bottom: 20px;
    overflow-x: scroll;
    height: 580px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .swiper::-webkit-scrollbar {
    display: none;
  }

  .swiper-slide {
    position: relative;
    border-radius: 10px;
  }

  .swiper-slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    cursor: pointer;
    background-color: #000; /* prevent flash of unstyled content */
  }

  .product-info {
    position: absolute;
    bottom: -4rem;
    text-align: center;
    width: 100%;
    color: black;
  }

  .product-info img {
    border-radius: 50%;
    margin: auto;
  }

  @media only screen and (min-width: 768px){
  .swiper-slide.video-wrapper{
    flex: 0 0 20%
  }    
  }
  /* @media only screen and (max-width: 767px){
  .swiper-slide.video-wrapper{
    flex: 0 0 80%
  }    
  } */


  .video-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: rgba(0,0,0,0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
  }

  .video-modal.hidden {
    display: none;
  }

  .video-modal-content {
    position: relative;
    max-width: 90%;
    max-height: 80%;
  }

  .video-modal-close {
    position: absolute;
    top: -30px;
    right: -10px;
    font-size: 2rem;
    color: white;
    cursor: pointer;
  }

  .video-modal-content .product-info {
    text-align: center;
    margin-top: 10px;
    color: white;
  }

  @media only screen and (min-width: 768px) {
    .swiper-slide {
      height: 500px;
    }
    .video-modal-content {
      max-width: 26%;
  
    }

  }
      .video-modal-content {
      top: 6% !important;
      position: absolute;
    }
    video#modal-video{
          height: 600px;
    }

  @media only screen and (max-width: 767px) {
    .swiper {
      height: 440px;
    }
    #video-modal .product-info {
      bottom: 8px;
    }
  }
</style>
