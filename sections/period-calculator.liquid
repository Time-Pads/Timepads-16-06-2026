<!-- ══ JAVASCRIPT ═════════════════════════════════════════════ -->
<script>
  // ── State ──────────────────────────────────────────────────
  let calYear, calMonth;
  let periodDates   = new Set();
  let fertileDates  = new Set();
  let ovulDates     = new Set();
  let nextPeriodDates = new Set();
  let hasCalculated = false;

  const MONTHS = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];

  // Set default date to today
  const today = new Date();
  document.getElementById('lastPeriod').value = today.toISOString().split('T')[0];
  calYear  = today.getFullYear();
  calMonth = today.getMonth();
  renderCalendar();

  // ── Calculate ──────────────────────────────────────────────
  function calculate() {
    const lpVal = document.getElementById('lastPeriod').value;
    if (!lpVal) { alert('Please enter the first day of your last period.'); return; }

    const lastPeriod  = new Date(lpVal);
    const periodLen   = parseInt(document.getElementById('periodLength').value);
    const cycleLen    = parseInt(document.getElementById('cycleLength').value);
    const nextPeriodStart = addDays(lastPeriod, cycleLen);

    // Clear previous
    periodDates.clear(); fertileDates.clear(); ovulDates.clear(); nextPeriodDates.clear();

    // Current period days
    for (let i = 0; i < periodLen; i++) {
      periodDates.add(dateKey(addDays(lastPeriod, i)));
    }

    // Ovulation = day 14 before next period (cycle - 14)
 const ovulStart = addDays(lastPeriod, (cycleLen - 16));
const ovulEnd   = addDays(lastPeriod, (cycleLen - 12));

for (let d = new Date(ovulStart); d <= ovulEnd; d.setDate(d.getDate() + 1)) {
  ovulDates.add(dateKey(new Date(d)));
}

    // Fertile window: 5 days before ovulation + ovulation day
  const fertileStart = addDays(ovulStart, -3);
const fertileEnd   = ovulEnd;

for (let d = new Date(fertileStart); d <= fertileEnd; d.setDate(d.getDate() + 1)) {
  if (!periodDates.has(dateKey(d))) {
    fertileDates.add(dateKey(new Date(d)));
  }
}

    // Next period start
// Generate next 3 cycles
let tempStart = new Date(lastPeriod);

for (let cycle = 1; cycle <= 3; cycle++) {
  tempStart = addDays(lastPeriod, cycleLen * cycle);

  for (let i = 0; i < periodLen; i++) {
    nextPeriodDates.add(dateKey(addDays(tempStart, i)));
  }
}

    // Format results
    document.getElementById('res-next').textContent    = formatDate(nextPeriodStart);
    document.getElementById('res-fertile').textContent = formatDate(fertileStart) + ' – ' + formatDate(fertileEnd);
    document.getElementById('res-ovul').textContent = formatDate(ovulStart) + ' – ' + formatDate(ovulEnd);
    document.getElementById('resultsRibbon').classList.add('show');
    document.getElementById('calLegend').style.display = 'flex';
    document.getElementById('calPlaceholder').style.display = 'none';
    hasCalculated = true;

    // Jump to the month of last period
     calYear  = lastPeriod.getFullYear();
     calMonth = lastPeriod.getMonth();
     renderCalendar();

    // Smooth scroll to calendar on mobile
    document.querySelector('.calc-calendar').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Calendar Render ───
  function renderCalendar() {
    document.getElementById('calMonthLabel').textContent = MONTHS[calMonth] + ' ' + calYear;

    const grid = document.getElementById('calGrid');
    // Keep day name headers (first 7 children)
    while (grid.children.length > 7) grid.removeChild(grid.lastChild);

    const firstDay = new Date(calYear, calMonth, 1).getDay();
    const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();

    // Empty cells before first day
    for (let i = 0; i < firstDay; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day empty';
      grid.appendChild(el);
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(calYear, calMonth, d);
      const key  = dateKey(date);
      const el   = document.createElement('div');
      el.className = 'cal-day';
      el.textContent = d;

      if (key === dateKey(today)) el.classList.add('today');
      if (periodDates.has(key))     { el.classList.add('period');      el.title = 'Period day'; }
      if (fertileDates.has(key))    { el.classList.add('fertile');     el.title = 'Fertile window'; }
      if (ovulDates.has(key))       { el.classList.add('ovulation');   el.title = 'Ovulation day'; }
      if (nextPeriodDates.has(key)) { el.classList.add('next-period'); el.title = 'Predicted next period'; }

      grid.appendChild(el);
    }
  }

  function prevMonth() {
    calMonth--;
    if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar();
  }

  function nextMonth() {
    calMonth++;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar();
  }

  // ── FAQ Toggle ─────────────────────────────────────────────
  function toggleFaq(el) {
    const item = el.parentElement;
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }

  // ── Helpers ────────────────────────────────────────────────
  function addDays(date, days) {
    const d = new Date(date);
    d.setDate(d.getDate() + days);
    return d;
  }

  function dateKey(date) {
    return date.getFullYear() + '-' + (date.getMonth()+1) + '-' + date.getDate();
  }

  function formatDate(date) {
    return date.toLocaleDateString('en-IN', { day:'numeric', month:'short' });
  }
</script>


