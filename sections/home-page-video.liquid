{% schema %}
{
  "name": "Video Banners",
  "settings": [
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video"
    },
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Redirect URL"
    }
  ],
  "presets": [
    {
      "name": "Video Banners"
    }
  ]
}
{% endschema %}

<style>
  .video-banner {
    position: relative;
    width: 100%;
    height: auto;
    cursor: pointer;
  }

  /* .video-banner video {
    width: 100%;
    height: auto;
    display: block;
  } */
.video-banner video {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Ensures video covers the container without black bars */
    display: block;
}

  @media (max-width: 768px) {
    .video-banner .desktop-video {
      display: none;
    }
  }

  @media (min-width: 769px) {
    .video-banner .mobile-video {
      display: none;
    }
  }
</style>

<a href="{{ section.settings.redirect_url }}" class="video-banner">
  {% if section.settings.desktop_video %}
    <video class="desktop-video" autoplay loop muted playsinline>
      <source src={{ section.settings.desktop_video | video_tag }}
    </video>
  {% endif %}

  {% if section.settings.mobile_video %}
    <video class="mobile-video" autoplay loop muted playsinline>
      <source src={{ section.settings.mobile_video | video_tag }}
    </video>
  {% endif %}
</a>
