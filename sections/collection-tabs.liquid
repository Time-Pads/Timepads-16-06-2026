{% schema %}
{
  "name": "Collection Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Explore Our Collections"
    },
    {
      "type": "range",
      "id": "grid",
      "label": "Products per row (Desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_mobile",
      "label": "Products per row (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "coming_soon_text",
          "label": "Coming soon text"
        },
        {
          "type": "image_picker",
          "id": "header_image",
          "label": "Tab Image (Always Visible)"
        },
        {
          "type": "text",
          "id": "header_title",
          "label": "Header Title",
          "default": "Collection Title"
        },
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Name"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "URL"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection Tabs"
    }
  ]
}
{% endschema %}

{%- assign ct_product_limit = section.settings.grid | times: 2 -%}

<style>
  #ct-section-{{ section.id }} {
    --ct-grid: {{ section.settings.grid }};
    --ct-grid-mobile: {{ section.settings.grid_mobile }};
  }
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }

  /* ── Collection Tabs ── */
  .ct-collection-tabs {
    text-align: center;
  }

  .circle-collections-heading {
    margin: 0 0 16px;
    padding: 0;
    text-transform: capitalize;
  }

  /* Nav */
  .ct-tabs-nav {
    display: flex;
    gap: 22px;
    justify-content: center;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 10px;
    width: 90%;
    margin: 0 auto 25px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  /* Tab header item */
  .ct-collection-tabs-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
    cursor: pointer;
    position: relative;
    flex: 0 0 12%;
    transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  .ct-collection-tabs-header:hover {
    transform: translateY(-3px);
  }

  /* Image */
  .ct-header-image {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 0;
    transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  .ct-collection-tabs-header:hover .ct-header-image {
    transform: scale(1.05);
  }

  /* Tab button */
  .ct-tab-btn {
    background: none;
    border: none;
    padding: 6px 10px;
    font-size: 14px;
    color: #222;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: border-color 0.25s ease, color 0.25s ease;
    width: 100%;
    white-space: normal;
  }

  .ct-tab-btn.ct-active {
    font-weight: 700;
    border-bottom-color: #000;
    color: #000;
  }

  /* Panels visible immediately — removing opacity:0 gate which was delaying LCP paint timestamp */
  .ct-tab-panel { contain: layout style paint; }
  .ct-tab-panel:not(.ct-active) { display: none; }
  .ct-tab-panel.ct-active { display: block; }

  /* Product grid */
  .ct-products-grid {
    display: grid;
    grid-template-columns: repeat(var(--ct-grid), 1fr);
    gap: 20px;
    margin: 20px auto 0;
    width: 90%;
  }

  /* Coming soon badge */
  .coming-soon-text-default {
    background: #f83a3a;
    padding: 5px;
    border-radius: 10px;
    color: #fff;
    position: absolute;
    font-size: 9px;
    font-weight: 900;
    right: 0;
    top: 0;
    z-index: 1;
  }

  /* View all */
  .ct-view-all-wrapper { margin-top: 25px; }
  .ct-view-all-btn {
    padding: 10px 22px;
    background: #000;
    color: #fff;
    display: inline-block;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .ct-view-all-btn:hover { opacity: 0.8; }

  /* Product card overrides */
  product-form.product__block__buttons { display: none !important; }

  .ct-tabs-content .product__grid__title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ct-tabs-content .variant-label { color: #000 !important; font-weight: 600 !important; }
  .ct-tabs-content .add-to-cart-button-card { padding-top: 0; margin-bottom: 0.6rem; }

  .ct-tabs-content .free-shipping-text-product {
    height: 40px;
    position: relative;
    margin-top: 3rem;
  }
  .ct-tabs-content .free-shipping-text-product img { position: absolute; bottom: 5px; }
  .ct-tabs-content .product-card.single-variant { height: 7rem; }
.circle-collections-heading{
  font-size: 26px !important;
}
  /* ── Mobile ── */
  @media (max-width: 768px) {
    .circle-collections-heading {
      font-size: 20px !important;
      font-weight: 800 !important;
      letter-spacing: 1px !important;
    }

    .ct-products-grid {
      grid-template-columns: repeat(var(--ct-grid-mobile), 1fr);
    }

    .coming-soon-text-default { font-size: 5px; }

    .ct-tabs-nav {
      gap: 10px;
      margin-bottom: 0;
      padding-bottom: 0;
      justify-content: flex-start;
      margin-bottom: 2rem;
    }

    .ct-collection-tabs-header { flex: 1 0 28%; padding: 0; }
    .ct-tab-btn { font-size: 9px; }

    .template-index .product__grid__title { font-size: 14px; }
    .template-index .radio__button span { font-size: 9px; }

    .ct-tabs-content .free-shipping-text-product {
      height: 7px;
      margin-top: 3rem;
    }
    .ct-tabs-content .free-shipping-text-product img {
      position: relative;
      bottom: 10px;
    }
    .ct-tabs-content .radio__button label { padding: 10px; }
    .ct-tabs-content .product-card.single-variant { min-height: 8rem; }
  }
</style>

<div id="ct-section-{{ section.id }}" class="ct-collection-tabs" data-section-id="{{ section.id }}">

  {%- if section.settings.heading != blank -%}
    <div class="circle-collections-section">
      <h2 class="circle-collections-heading">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="ct-tabs-nav" role="tablist">
    {%- for block in section.blocks -%}
      <div class="ct-collection-tabs-header" {{ block.shopify_attributes }}>

        {%- if block.settings.coming_soon_text != blank -%}
          <p class="coming-soon-text-default" aria-label="Coming soon">
            {{ block.settings.coming_soon_text }}
          </p>
        {%- endif -%}

        {%- if block.settings.header_image != blank -%}
          {%- assign img     = block.settings.header_image -%}
          {%- liquid
            assign img_w = img.width | at_most: 220
            if forloop.first
              assign img_w    = 400
              assign img_load  = 'eager'
              assign img_fetch = 'low'
            else
              assign img_load  = 'eager'
              assign img_fetch = 'low'
            endif
            assign img_w2x = img_w | times: 2 | at_most: img.width
            assign img_alt = block.settings.tab_label | default: shop.name
          -%}

          {%- if block.settings.collection_url != blank -%}
            <a href="{{ block.settings.collection_url }}" class="ct-image-link" tabindex="-1" aria-hidden="true">
          {%- endif -%}

            <div class="ct-image-wrapper loading-shimmer" style="aspect-ratio: 1 / 1; border-radius: 50%; overflow: hidden; background-color: #f5f5f5; width: 100%; margin-bottom: 6px;">
              <picture>
                <source
                  type="image/webp"
                  srcset="{{ img | image_url: width: img_w, format: 'webp' }} 1x, {{ img | image_url: width: img_w2x, format: 'webp' }} 2x"
                >
                <img
                  src="{{ img | image_url: width: img_w }}"
                  srcset="{{ img | image_url: width: img_w }} 1x, {{ img | image_url: width: img_w2x }} 2x"
                  sizes="(max-width: 767px) 28vw, 12vw"
                  width="{{ img_w }}"
                  height="{{ img_w }}"
                  alt="{{ img_alt | escape }}"
                  class="ct-header-image"
                  loading="{{ img_load }}"
                  fetchpriority="{{ img_fetch }}"
                  decoding="async"
                  onload="if(this.complete) { var w = this.closest('.ct-image-wrapper'); if(w) { w.classList.remove('loading-shimmer'); w.style.backgroundColor = 'transparent'; } }"
                >
              </picture>
            </div>

          {%- if block.settings.collection_url != blank -%}
            </a>
          {%- endif -%}
        {%- endif -%}

        <button
          class="ct-tab-btn{% if forloop.first %} ct-active{% endif %}"
          type="button"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          data-tab-index="{{ forloop.index0 }}"
        >
          {{ block.settings.tab_label }}
        </button>

      </div>
    {%- endfor -%}
  </div>

  <div class="ct-tabs-content" data-section-ready="true">
    {%- assign first_block = section.blocks | first -%}
    {%- if first_block -%}
      {%- assign first_collection = first_block.settings.collection -%}
      {%- assign first_collection_url = first_block.settings.collection_url | default: first_collection.url -%}
      <div class="ct-tab-panel ct-active" data-tab-panel="0">
        {%- if first_collection != blank and first_collection.products_count > 0 -%}
          <div class="ct-products-grid">
            {%- for product in first_collection.products limit: ct_product_limit -%}
              {%- render 'product-card-home-page',
                product: product,
                placeholder: 'product',
                columns_desktop: section.settings.grid,
                columns_mobile: section.settings.grid_mobile
              -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

      {% comment %}  {%- if first_collection_url != blank -%}
          <div class="ct-view-all-wrapper">
            <a class="ct-view-all-btn" href="{{ first_collection_url }}">View all</a>
          </div>
        {%- endif -%} {% endcomment %}
      </div>
    {%- endif -%}
  </div>

  {%- for block in section.blocks -%}
    {%- unless forloop.first -%}
      {%- assign inactive_collection = block.settings.collection -%}
      {%- assign inactive_collection_url = block.settings.collection_url | default: inactive_collection.url -%}
      <template data-ct-tab-template="{{ forloop.index0 }}">
        <div class="ct-tab-panel" data-tab-panel="{{ forloop.index0 }}">
          {%- if inactive_collection != blank and inactive_collection.products_count > 0 -%}
            <div class="ct-products-grid">
              {%- for product in inactive_collection.products limit: ct_product_limit -%}
                {%- render 'product-card-home-page',
                  product: product,
                  placeholder: 'product',
                  columns_desktop: section.settings.grid,
                  columns_mobile: section.settings.grid_mobile
                -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if inactive_collection_url != blank -%}
            <div class="ct-view-all-wrapper">
              <a class="ct-view-all-btn" href="{{ inactive_collection_url }}">View all</a>
            </div>
          {%- endif -%}
        </div>
      </template>
    {%- endunless -%}
  {%- endfor -%}

</div>

<script>
  (function () {
    function initCollectionTabs(section) {
      if (!section || section.hasAttribute('data-ct-tabs-bound')) return;

      var buttons = Array.prototype.slice.call(section.querySelectorAll('.ct-tab-btn'));
      var content = section.querySelector('.ct-tabs-content');
      if (!buttons.length || !content) return;

      section.setAttribute('data-ct-tabs-bound', 'true');

      function ensurePanel(index) {
        var existingPanel = content.querySelector('[data-tab-panel="' + index + '"]');
        if (existingPanel) return existingPanel;

        var template = section.querySelector('template[data-ct-tab-template="' + index + '"]');
        if (!template) return null;

        var fragment = template.content.cloneNode(true);
        content.innerHTML = '';
        content.appendChild(fragment);
        return content.querySelector('[data-tab-panel="' + index + '"]');
      }

      function activateTab(index) {
        buttons.forEach(function (button) {
          var isActive = button.getAttribute('data-tab-index') === String(index);
          button.classList.toggle('ct-active', isActive);
          button.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        content.querySelectorAll('.ct-tab-panel').forEach(function (panel) {
          panel.classList.remove('ct-active');
        });

        var panel = ensurePanel(index);
        if (panel) {
          panel.classList.add('ct-active');
          document.dispatchEvent(new CustomEvent('theme:tab:change', { bubbles: true }));
        }

        content.setAttribute('data-section-ready', 'true');
      }

      buttons.forEach(function (button) {
        button.addEventListener('click', function () {
          activateTab(button.getAttribute('data-tab-index'));
        });
      });

      activateTab(buttons[0].getAttribute('data-tab-index'));
    }

    document.querySelectorAll('.ct-collection-tabs').forEach(initCollectionTabs);

    document.addEventListener('shopify:section:load', function (event) {
      initCollectionTabs(event.target.querySelector('.ct-collection-tabs'));
    });
  }());
</script>
