<!-- /sections/image-columns-with-text.liquid -->

{%- comment -%} ── Lazy-load gate ── {%- endcomment -%}
{%- capture lazy_load_section -%}{%- render 'lazy-load-section-validations' -%}{%- endcapture -%}

{%- comment -%} ── Scoped vars ── {%- endcomment -%}
{%- assign sid  = section.id -%}
{%- assign pt   = section.settings.padding_top -%}
{%- assign pb   = section.settings.padding_bottom -%}
{%- assign mpt  = section.settings.padding_top_mobile -%}
{%- assign mpb  = section.settings.padding_bottom_mobile -%}

{% style %}
  .section-padding-{{ sid }} {
    padding-top: {{ pt }}px;
    padding-bottom: {{ pb }}px;
  }
  @media (max-width: 767px) {
    .section-padding-{{ sid }} {
      padding-top: {{ mpt }}px;
      padding-bottom: {{ mpb }}px;
    }
  }
  /* Scope read-more styles to this section to avoid cross-section conflicts */
  #shopify-section-{{ sid }} .text-container {
    max-height: 30px;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  #shopify-section-{{ sid }} .text-container.expanded {
    max-height: none;
  }
  #shopify-section-{{ sid }} .read-more-btn {
    margin-top: 10px;
    background: transparent;
    font-weight: 500;
    border: none;
    padding: 10px;
    cursor: pointer;
    border-radius: 5px;
    font-size: 14px;
    color: #2d2a2a;
  }
  #shopify-section-{{ sid }} .read-more-btn:hover { color: #fff; }
  .index__column.grid__item.slide-item.text-center h3{
    font-size: 16px;
  }
{% endstyle %}

{%- if lazy_load_section != blank -%}<lazy-section>{%- endif -%}

{%- if lazy_load_section == blank -%}

  <div
    class="section-columns {{ section.settings.extra_class }} {{ section.settings.bg }}"
    data-section-id="{{ sid }}"
    data-section-type="section-columns"
  >
    <div class="{{ section.settings.width }} section-padding-{{ sid }}">

      {%- if section.settings.title != blank -%}
        <h2 class="kicker-flourished mb-r11">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      <div
        data-grid
        data-grid-flex
        data-grid-large
        data-grid-medium
        data-grid-small
        data-custom-scrollbar-items
        style="--grid-large-items:{{ section.settings.grid_large }};--grid-medium-items:{{ section.settings.grid_medium }};--grid-small-items:{{ section.settings.grid_mobile }};"
      >
        {%- for block in section.blocks -%}
          {%- comment -%} First block is above the fold — load eagerly {%- endcomment -%}
          {%- assign img_loading = forloop.first | iif: 'eager', 'lazy' -%}

          <div
            class="index__column grid__item slide-item {{ section.settings.align_text }}"
            data-item
            {{ block.shopify_attributes }}
          >

            {%- if block.settings.enable_image and block.settings.image != blank -%}
              <div class="column__image" data-grid-slide>

                {%- capture sizes -%}
                  {%- render 'image-grid-sizes',
                    columns_desktop: section.settings.grid_large,
                    columns_tablet:  section.settings.grid_large,
                    columns_mobile:  section.settings.grid_mobile,
                    section_width:   section.settings.width,
                    alt:             block.settings.alt_text
                  -%}
                {%- endcapture -%}

                {%- capture srcset -%}
                  {%- render 'image-grid-srcset',
                    image:           block.settings.image,
                    columns_desktop: section.settings.grid_large,
                    columns_tablet:  section.settings.grid_large,
                    columns_mobile:  section.settings.grid_mobile,
                    section_width:   section.settings.width,
                    alt:             block.settings.alt_text
                  -%}
                {%- endcapture -%}

                {%- render 'responsive-picture',
                  forloop:      forloop,
                  cover:        true,
                  desktopImage: block.settings.image,
                  mobileImage:  block.settings.image,
                  srcset:       srcset,
                  sizes:        sizes,
                  alt:          block.settings.alt_text,
                  loading:      img_loading,
                  class:        block.settings.shape_class,
                  wh_ratio:     section.settings.wh_ratio,
                  img-class:    'tw-w-full tw-max-h-[60rem]'
                -%}

                {%- if block.settings.enable_video -%}
                  <div class="{{ block.settings.video_button_color }}">
                    {%- render 'video-popup', video: block.settings.video_link, unique: block.id -%}
                  </div>
                {%- elsif block.settings.button_label == blank and block.settings.button_link != blank -%}
                  <a
                    class="link-over-image"
                    href="{{ block.settings.button_link }}"
                    aria-label="{{ block.settings.title | strip_html | escape }}"
                  ></a>
                {%- endif -%}

              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <div class="accent-title-large strong mb-r4">{{ block.settings.title | escape }}</div>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="rte body-size-4 text-container" data-read-more-text>
                {{ block.settings.text }}
              </div>
              <div class="read-more-text-block">
                <button class="read-more-btn" type="button" aria-expanded="false">Read More</button>
              </div>
            {%- endif -%}

            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <a
                href="{{ block.settings.button_link }}"
                class="{{ block.settings.button_color }} {{ block.settings.button_style }}"
              >
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.progress_bar_mobile -%}
        <div class="custom-scrollbar small-down--show" data-custom-scrollbar>
          <div class="custom-scrollbar__track" data-custom-scrollbar-track></div>
        </div>
      {%- endif -%}

      {%- if section.blocks.size == 0 -%}
        <div class="text-center">{{ 'home_page.onboarding.no_content' | t }}</div>
      {%- endif -%}

    </div>
  </div>

{%- else -%}
  <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg" width="66" height="66">
    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
  </svg>
{%- endif -%}

{%- if lazy_load_section != blank -%}</lazy-section>{%- endif -%}

{%- comment -%}
  Read-more JS — loaded once globally via a flag so multiple instances
  of this section don't stack duplicate listeners.
{%- endcomment -%}
<script>
(function () {
  if (window.__readMoreInit) return; // guard: only initialise once per page
  window.__readMoreInit = true;

  /* ── hide button when content fits in collapsed height ── */
  function initButtons(root) {
    root.querySelectorAll('[data-read-more-text]').forEach(function (container) {
      var btn = container.nextElementSibling && container.nextElementSibling.querySelector('.read-more-btn');
      if (btn && container.scrollHeight <= 32) {
        btn.hidden = true;
      }
    });
  }

  /* ── toggle handler (single delegated listener on document) ── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.read-more-btn');
    if (!btn) return;

    var container = btn.closest('.index__column, .slide-item, .grid__item')
                       ?.querySelector('[data-read-more-text]');
    if (!container) return;

    var expanded = container.classList.toggle('expanded');
    btn.textContent   = expanded ? 'Read Less' : 'Read More';
    btn.setAttribute('aria-expanded', String(expanded));
  }, { passive: true });

  /* ── run on initial load ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initButtons(document); }, { once: true });
  } else {
    initButtons(document);
  }

  /* ── re-run when a lazy section loads ── */
  document.addEventListener('shopify:section:load', function (e) {
    initButtons(e.target);
  });
}());
</script>

{% schema %}
{
  "name": "image columns with text",
  "settings": [
    { "type": "header", "content": "Padding settings" },
    { "type": "range", "id": "padding_top",          "min": 0, "max": 100, "default": 20, "step": 2, "unit": "px", "label": "Padding Top" },
    { "type": "range", "id": "padding_bottom",        "min": 0, "max": 100, "default": 20, "step": 2, "unit": "px", "label": "Padding Bottom" },
    { "type": "range", "id": "padding_top_mobile",    "min": 0, "max": 100, "default": 20, "step": 2, "unit": "px", "label": "Padding Top Mobile" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "default": 20, "step": 2, "unit": "px", "label": "Padding Bottom Mobile" },
    { "type": "text",   "id": "title",       "label": "Kicker",          "default": "Text columns with images" },
    { "type": "text",   "id": "extra_class", "label": "Extra class",     "default": "image-colums-with-text" },
    {
      "type": "select", "id": "bg", "label": "Background color", "default": "palette--light bg--neutral",
      "options": [
        { "value": "palette--light bg--neutral",         "label": "Default" },
        { "value": "palette--light bg--accent",          "label": "Light" },
        { "value": "palette--dark bg--invert",           "label": "Dark" },
        { "value": "palette--dark bg--invert--accent",   "label": "Dark accent" },
        { "value": "palette--bright bg--bright",         "label": "Bright" },
        { "value": "palette--bright bg--bright--accent", "label": "Bright accent" }
      ]
    },
    {
      "type": "select", "id": "align_text", "label": "Text alignment", "default": "text-center",
      "options": [
        { "value": "text-left",   "label": "Left" },
        { "value": "text-center", "label": "Centered" },
        { "value": "text-right",  "label": "Right" }
      ]
    },
    { "type": "header",   "content": "Images" },
    { "type": "checkbox", "id": "scale_image", "label": "Scale images", "default": true },
    { "type": "range",    "id": "wh_ratio", "min": 0.5, "max": 5, "step": 0.1, "unit": ":1", "label": "Image scaling ratio", "info": "Tall to wide", "default": 1 },
    { "type": "header",   "content": "Items per row" },
    { "type": "range",    "id": "grid_large",  "min": 3, "max": 6, "step": 1,   "label": "Desktop", "default": 3 },
    { "type": "range",    "id": "grid_medium", "min": 1, "max": 4, "step": 1,   "label": "Tablet",  "default": 3 },
    { "type": "range",    "id": "grid_mobile", "min": 1, "max": 3, "step": 0.1, "label": "Mobile",  "default": 1.2 },
    { "type": "checkbox", "id": "progress_bar_mobile", "label": "Show mobile scrollbar", "default": false },
    { "type": "header",   "content": "Section spacing" },
    {
      "type": "select", "id": "width", "label": "Width", "default": "wrapper",
      "options": [
        { "value": "wrapper--full",   "label": "Full width padded" },
        { "value": "wrapper",         "label": "Page width" },
        { "value": "wrapper--narrow", "label": "Page width narrow" },
        { "value": "wrapper--tiny",   "label": "Page width extra narrow" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Column",
      "settings": [
        { "type": "checkbox",     "id": "enable_image", "label": "Show image", "default": true },
        { "type": "image_picker", "id": "image",        "label": "Image" },
        { "type": "text",         "id": "alt_text",     "label": "Image Alt text" },
        {
          "type": "select", "id": "shape_class", "label": "Shape", "default": "",
          "options": [
            { "value": "",                    "label": "None" },
            { "value": "rounded-lg",          "label": "Rounded" },
            { "value": "radius-keyhole",      "label": "Keyhole" },
            { "value": "rounded-full",        "label": "Circle" },
            { "value": "clip-sunburst",       "label": "Sunburst" },
            { "value": "clip-hexagon",        "label": "Hexagon" },
            { "value": "clip-octagon",        "label": "Octagon" },
            { "value": "clip-parallelogram",  "label": "Parallelogram" },
            { "value": "radius-blob-1",       "label": "Blob 1" },
            { "value": "radius-blob-2",       "label": "Blob 2" },
            { "value": "radius-blob-3",       "label": "Blob 3" },
            { "value": "radius-blob-4",       "label": "Blob 4" },
            { "value": "mask-stamp-sharp",    "label": "Stamp sharp" },
            { "value": "mask-stamp-rounded",  "label": "Stamp rounded" },
            { "value": "mask-ticket-stub",    "label": "Ticket" }
          ]
        },
        { "type": "text",     "id": "title",        "label": "Title",  "default": "Feature images or videos" },
        { "type": "richtext", "id": "text",         "label": "Text",   "default": "<p>Add a video popup link to show a play button. Share blog posts, products, or promotions with your customers.</p>" },
        { "type": "text",     "id": "button_label", "label": "Button label", "info": "Leave blank to link from image" },
        { "type": "url",      "id": "button_link",  "label": "Button link" },
        {
          "type": "select", "id": "button_color", "label": "Color", "default": "btn--neutral",
          "options": [
            { "value": "btn--primary",   "label": "Bright accent" },
            { "value": "btn--secondary", "label": "Secondary accent" },
            { "value": "btn--neutral",   "label": "Text color" },
            { "value": "btn--black",     "label": "Black" },
            { "value": "btn--white",     "label": "White" }
          ]
        },
        {
          "type": "select", "id": "button_style", "label": "Button style", "default": "btn--soft",
          "options": [
            { "value": "btn-text-thick-line", "label": "Capitalized text" },
            { "value": "btn",                 "label": "Solid button" },
            { "value": "btn--soft",           "label": "Soft button" },
            { "value": "btn--outline",        "label": "Outlined button" }
          ]
        },
        { "type": "header",   "content": "Video Popup" },
        { "type": "checkbox", "id": "enable_video",        "label": "Show video",   "default": false },
        { "type": "video_url","id": "video_link",          "label": "Video link",   "accept": ["youtube","vimeo"], "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc", "info": "YouTube or Vimeo accepted." },
        {
          "type": "select", "id": "video_button_color", "label": "Color", "default": "text--white",
          "options": [
            { "value": "text--neutral",            "label": "Normal text" },
            { "value": "text--white",              "label": "White" },
            { "value": "text--primary",            "label": "Primary accent" },
            { "value": "text--secondary",          "label": "Secondary accent" },
            { "value": "text--black",              "label": "Black" },
            { "value": "text--invert--primary",    "label": "Primary dark accent" },
            { "value": "text--invert--secondary",  "label": "Secondary dark accent" },
            { "value": "text--invert",             "label": "Inverted text color" },
            { "value": "text--bright--primary",    "label": "Primary bright accent" },
            { "value": "text--bright--secondary",  "label": "Secondary bright accent" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "image columns with text",
      "category": "Text",
      "blocks": [
        { "type": "text_block" },
        { "type": "text_block" },
        { "type": "text_block" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header","aside"]
  }
}
{% endschema %}
