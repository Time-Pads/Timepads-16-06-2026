{% stylesheet %}
.launch-form-wrapper {
  max-width: 600px;
  margin: 40px auto;
  padding: 30px 25px;
  background: #ffffff;
  border-radius: 18px;
  box-shadow: 0 6px 30px rgba(0,0,0,0.08);
  font-family: 'Inter', sans-serif;
  font-display: swap;
}

.launch-form-wrapper h2 {
  font-size: 30px;
  font-weight: 700;
  margin-bottom: 10px;
  color: #1a1a1a;
  text-align: center;
}

.launch-form-wrapper p.desc {
  font-size: 14px;
  color: #555;
  margin-bottom: 25px;
  line-height: 1.5;
  text-align: center;
}

.launch-label {
  font-size: 15px;
  font-weight: 600;
  color: #2a2a2a;
  margin-bottom: 6px;
  display: block;
}

.launch-input,
.launch-select,
.launch-textarea {
  width: 100%;
  padding: 12px 14px;
  font-size: 15px;
  border-radius: 10px;
  border: 1px solid #d8d8d8;
  margin-bottom: 18px;
  outline: none;
  transition: border-color 0.25s, box-shadow 0.25s;
}

.launch-input:focus,
.launch-select:focus,
.launch-textarea:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
}

.launch-submit {
  width: 100%;
  background: #1f2937;
  color: #fff;
  padding: 14px 0;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.25s;
}

.launch-submit:hover {
  background: #111827;
}

#exclusive-launch-form {
  transition: opacity 0.4s ease;
}

#success-box {
  display: none;
  text-align: center;
  margin-top: 20px;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.6s ease, transform 0.6s ease;
  font-size: 20px;
  font-weight: 600;
  color: #dc2626;
}

#success-box.show {
  opacity: 1;
  transform: translateY(0);
}

#user-count {
  font-size: 16px;
  color: #555;
  margin-top: 8px;
}

#loading {
  text-align: center;
  margin-top: 15px;
  font-size: 14px;
}
{% endstylesheet %}

<div class="launch-form-wrapper">
  <h2>{{ section.settings.heading }}</h2>
  <p class="desc">{{ section.settings.description }}</p>

  <form id="exclusive-launch-form" method="post" novalidate>
    <input type="hidden" name="Tag" value="Exclusive Launch Alert">

    <label class="launch-label">Name *</label>
    <input class="launch-input" type="text" name="Name" required placeholder="Your Name">

    <label class="launch-label">Email *</label>
    <input class="launch-input" type="email" name="Email" required placeholder="example@email.com">

    <label class="launch-label">Phone *</label>
    <input class="launch-input" type="tel" name="Phone" required placeholder="Your Phone Number">

    <label class="launch-label">Product</label>
    <select class="launch-select" name="Product">
      <option>Menstrual Cups</option>
      <option>Mind Relax Cream</option>
      <option>Period Pain Relief Cream</option>
      <option>Panty Liner</option>
    </select>

    <label class="launch-label">Comment</label>
    <textarea class="launch-textarea" name="Comment" rows="3" placeholder="Your message..."></textarea>

    <button type="submit" id="submitBtn" class="launch-submit">Submit</button>
  </form>

  <div id="loading" style="display:none;">⏳ Submitting, please wait...</div>

  <div id="success-box">
    <strong>🚀 Welcome to the VIP list!</strong>
    <p>Your spot is confirmed — you’ll be among the first to receive early access, updates, and surprises.</p>
    <div id="user-count"></div>
  </div>
</div>

<script defer>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("exclusive-launch-form");
  if (!form) return;

  const submitBtn = document.getElementById("submitBtn");
  const loader = document.getElementById("loading");
  const successBox = document.getElementById("success-box");
  const userCountText = document.getElementById("user-count");

  form.addEventListener("submit", function (e) {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";
    loader.style.display = "block";

    const formData = new FormData(form);

    fetch("https://script.google.com/macros/s/AKfycbzU7vo1rvbAwXIw1CFpPN3ci8JroiQrvI1GlwOHV6lGTTe90dO_Jo0MCy005GJlmP9m4g/exec", {
      method: "POST",
      body: formData
    })
    .then(res => res.json())
    .then(data => {
      loader.style.display = "none";
      form.style.opacity = "0";

      setTimeout(() => {
        form.style.display = "none";

        if (data.row) {
          userCountText.textContent = `✨ You are user #${data.row} to sign up!`;
        }

        successBox.style.display = "block";
        requestAnimationFrame(() => successBox.classList.add("show"));
      }, 300);
    })
    .catch(() => {
      loader.style.display = "none";
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit";
      alert("❌ Something went wrong. Please try again.");
    });
  });
});
</script>

{% schema %}
{
  "name": "Exclusive Launch Alerts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Form Heading",
      "default": "Exclusive Launch Alerts"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Form Description",
      "default": "Join our VIP list to get early access, product updates, and special surprises."
    }
  ],
  "presets": [
    {
      "name": "Exclusive Launch Alerts"
    }
  ]
}
{% endschema %}
