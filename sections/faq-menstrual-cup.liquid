<style>
.time-faq {
  background: #f6f1ea;
  padding: 40px 20px;
  width: 90%;
  margin: auto;
}
.faq-title {
  text-align: center;
  font-size: 28px;
  color: #77350f;
  margin-bottom: 30px;
}
.faq-wrapper {
  max-width: 850px;
  margin: auto;
}
.faq-item {
  background: #fff;
  border-radius: 16px;
  margin-bottom: 14px;
  border-left: 5px solid #AB7841;
}
.faq-item summary {
  list-style: none;
  -webkit-appearance: none; /* Safari */
  padding: 18px;
  cursor: pointer;
  font-weight: 600;
  color: #77350f;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}
.faq-item summary::-webkit-details-marker { display: none; } /* Chrome/Safari */
.faq-item[open] .faq-icon { transform: rotate(45deg); }
.faq-answer {
  padding: 0 18px 18px;
  color: #444;
  line-height: 1.6;
}
.faq-icon {
  transition: transform 0.2s ease;
  flex-shrink: 0;
  font-style: normal;
}
</style>

{%- if section.blocks.size > 0 -%}
<section class="time-faq page-width" data-section-id="{{ section.id }}">

  {%- if section.settings.heading != blank -%}
    <h2 class="faq-title">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="faq-wrapper">
    {%- comment -%} FAQ structured data — helps Google show rich results {%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank and block.settings.answer != blank -%}
            {
              "@type": "Question",
              "name": {{ block.settings.question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ block.settings.answer | json }}
              }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    </script>

    {%- for block in section.blocks -%}
      {%- if block.settings.question != blank -%}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary>
            {{ block.settings.question | escape }}
            <i class="faq-icon" aria-hidden="true">+</i>
          </summary>
          {%- if block.settings.answer != blank -%}
            <div class="faq-answer">{{ block.settings.answer | escape }}</div>
          {%- endif -%}
        </details>
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>
{%- endif -%}

{% schema %}
{
  "name": "TIME FAQ Section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer",   "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "TIME FAQ Section" }]
}
{% endschema %}
