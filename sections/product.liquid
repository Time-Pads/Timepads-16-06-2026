{%- comment -%} All JS in ONE deferred block at the bottom ── {%- endcomment -%}
<script>
(function () {
  'use strict';

  /* ── Product description accordion (description-product block) ── */
  var detailsBtn = document.querySelector('#product-details .read-more-btn');
  if (detailsBtn) {
    detailsBtn.addEventListener('click', function () {
      var holder  = document.querySelector('#product-details .product-description__holder');
      var expanded = this.getAttribute('aria-expanded') === 'true';
      holder.style.maxHeight = expanded ? '100px' : holder.scrollHeight + 'px';
      this.textContent = expanded ? 'Read More' : 'Read Less';
      this.setAttribute('aria-expanded', String(!expanded));
    });
  }

  /* ── Extra info collapsible (Extrainfo block) ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initExtras, { once: true });
  } else {
    initExtras();
  }

  function initExtras() {
    var btn = document.querySelector('.collapsible-toggle');
    var desc = document.querySelector('.product-description-text');
    if (!btn || !desc) return;

    btn.addEventListener('click', function () {
      var isCollapsed = this.getAttribute('aria-expanded') === 'false';
      var colText = desc.getAttribute('data-collapsed-text');
      var expText = desc.getAttribute('data-expanded-text');
      var btnSpan = this.closest('span');

      desc.innerHTML = isCollapsed ? expText : colText;
      desc.appendChild(btnSpan);

      this.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
      this.textContent = isCollapsed
        ? this.getAttribute('data-expanded-label')
        : this.getAttribute('data-collapsed-label');
    });
  }

  /* ── LiveView custom element ── */
  if (!customElements.get('live-view')) {
    customElements.define('live-view', class extends HTMLElement {
      connectedCallback() {
        this._min      = parseInt(this.dataset.min)  || 10;
        this._max      = parseInt(this.dataset.max)  || 40;
        this._interval = parseInt(this.dataset.interval) || 10;
        this._msg      = this.dataset.message || '[count] people are viewing this right now';
        this._tick();
        this._timer = setInterval(() => this._tick(), this._interval * 1000);
      }
      disconnectedCallback() {
        clearInterval(this._timer); // no memory leak
      }
      _tick() {
        var count = Math.floor(Math.random() * (this._max - this._min + 1)) + this._min;
        this.textContent = this._msg.replace('[count]', count);
      }
    });
  }

}());
</script>

