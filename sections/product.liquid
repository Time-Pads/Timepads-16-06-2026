<!-- /sections/product.liquid -->

{%- comment -%} ── JSON-LD structured data — ONE clean block, no duplicates ── {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  {%- liquid
    assign seo_variant = product.selected_or_first_available_variant
    assign days_price_valid  = 1
    assign secs_in_day       = 86400
    assign price_valid_until = 'now' | date: '%s' | plus: secs_in_day | date: '%Y-%m-%d'
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "@id": "{{ product.url | absolute_url }}#product",
    "name": {{ product.title | json }},
    "image": [{% for img in product.images %}"{{ img | image_url: width: 1400 }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
    "description": {{ product.description | strip_html | escape | json }},
    "sku": "{{ seo_variant.sku }}",
    "brand": { "@type": "Brand", "name": "Timepads" },
    "category": "{% if collection %}{{ collection.title | escape }}{% else %}Sanitary Pads{% endif %}",
    "url": "{{ product.url | absolute_url }}",
    "offers": {
      "@type": "Offer",
      "url": "{{ product.url | absolute_url }}",
      "priceCurrency": "{{ shop.currency }}",
      "price": "{{ seo_variant.price | money_without_currency | strip_html }}",
      "priceValidUntil": "{{ price_valid_until }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "seller": { "@type": "Organization", "name": "Timepads" }
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "500"
    }
  }
  </script>
{%- endif -%}

{%- comment -%} ── ALL scoped styles in ONE block at the top ── {%- endcomment -%}
{% style %}
/* Badge */
.badge-bestseller {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgb(255,229,164);
  color: #000;
  font-size: 13px;
  font-weight: 600;
  padding: 6px 14px;
  border-radius: 999px;
  line-height: 1;
}

/* Benefit pills */
.product-benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 16px 0;
}
.product-benefits.cup .benefit-pill { font-size: 12px; }
.benefit-pill {
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  white-space: nowrap;
  border: 1px solid transparent;
}
.pill-1 { color: #b91c1c; border-color: #f5b5b5; }
.pill-2 { color: #0369a1; border-color: #bae6fd; }
.pill-3 { color: #15803d; border-color: #bbf7d0; }
.pill-4 { color: #6d28d9; border-color: #ddd6fe; }
.pill-5 { color: #c2410c; border-color: #fed7aa; }
.pill-6 { color: #9d174d; border-color: #fbcfe8; }

/* Certificates */
.product-certificates-block { margin: 20px 0; }
.product-certificates-block .certificates-heading { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
.product-certificates-block .certificates-grid { display: flex; gap: 24px; }
.product-certificates-block .certificate-item img { max-width: 80px; height: auto; }

/* Title */
.product__align-left .product__title { font-weight: 500; }

/* Urgency boxes */
.stock-urgency-box {
  display: inline-block;
  background: #fff3f3;
  border: 1px solid #ffcccc;
  padding: 8px 14px;
  border-radius: 8px;
  margin: 12px 0;
  font-weight: 600;
  font-size: 13px;
  color: #c62828;
}
.sales-urgency-box {
  background: #fff7f3;
  border: 1px solid #f4cfc2;
  padding: 10px 16px;
  border-radius: 12px;
}
.sales-line { font-weight: 600; font-size: 14px; color: #b85c38; }
.sales-sub  { font-size: 12px; color: #555; margin-top: 3px; }

/* Product description accordion */
.product-details {
  position: relative;
  border: 1px solid #ddd;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  margin-bottom: 1rem;
}
.product-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1.2rem;
  font-weight: bold;
  padding: 15px;
  background-color: #f7f7f7;
  cursor: pointer;
  border-bottom: 1px solid #ddd;
}
.product-summary:focus { outline: 2px solid #AB7841; }
.product-summary span  { font-size: 14px; font-weight: 800; }
#product-details b, #product-details strong, #product-details .strong { color: #000; font-weight: bold; }
.arrow-icon {
  display: inline-block;
  width: 10px; height: 10px;
  margin-left: 10px;
  border: solid #333;
  border-width: 2px 2px 0 0;
  transform: rotate(316deg);
  transition: transform 0.3s ease;
}
details[open] .arrow-icon { transform: rotate(135deg); }
.product-description__holder {
  padding: 15px;
  max-height: 100px;
  overflow: hidden;
  transition: max-height 0.3s ease;
  font-size: 12px;
  line-height: 1.5;
  color: #333;
}
.product-description__holder p { font-size: 14px; }
.product-description__holder h2 { font-size: 22px; font-weight: 900; }
.read-more-btn {
  display: block;
  width: 100%;
  text-align: center;
  background-color: #f7f7f7;
  color: #000;
  font-size: 14px;
  padding: 10px;
  border: none;
  cursor: pointer;
  transition: background-color 0.3s ease;
}
.read-more-btn:hover { background-color: #b7a487; }
details#product-details .read-more-btn { font-size: 14px; }
.read-more-btn[aria-expanded="true"] { background-color: #f7f7f7; }

/* Share icons */
.share-icon-pd { display: flex; align-items: center; gap: 11px; }
.share-text { line-height: 24px; font-size: clamp(10px, 2vw, 20px); font-weight: 600; color: #000; }
.share-container { display: flex; gap: 22px; }
.facebook img, .twitter img, .whatsapp img { margin: 0 !important; width: 32px; height: 32px; }

/* Guide card */
.guide-card { margin-bottom: 1rem; }
.guide-card h4 { font-size: 16px; margin-bottom: 0; font-weight: 800; }
.guide-card p  { margin-bottom: 15px; }
.guide-card a  { background: #ee3d43; color: #fff; padding: 5px; margin-top: 15px; border-radius: 10px; }

/* Live view */
.blinking-text { color: red; animation: blink-animation 3s infinite; }
@keyframes blink-animation {
  0%,100% { opacity: 1; font-weight: 900; font-size: 12px; }
  50%      { opacity: 0.5; font-size: 10px; }
}

/* Judge.me overrides */
.rating__wrapper__title { display: none; }
.jdgm-widget.jdgm-preview-badge.jdgm-preview-badge--with-link.jdgm--done-setup { margin: 1rem 0; }
.product__block__title { padding-bottom: 0 !important; }
span.jdgm-rev__timestamp { display: none; }

/* Payment icons */
.payment-icons-wrapper { margin-bottom: 12px; }
.payment-title { font-size: 13px; color: #77350f; margin-bottom: 8px; font-weight: 600; }
.payment-icons { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.payment-icons img { height: 50px; width: auto; background: #fff; border-radius: 35%; padding: 5px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
product-form.product__block__buttons { padding-bottom: 0; margin-bottom: 0; }

/* Misc */
.pdp-user-guide { margin-top: 15px; text-align: center; }
.pdp-user-guide a { display: inline-block; background: #AB7841; color: #fff; padding: 12px 18px; border-radius: 30px; font-size: 14px; font-weight: 600; text-decoration: none; transition: background 0.3s; }
.pdp-user-guide a:hover { background: #77350f; }

@media (min-width: 769px) {
  .sales-urgency-box, .stock-urgency-box { width: 68%; }
}
@media (max-width: 767px) {
  .badge-bestseller { padding: 4px; font-size: 9px; margin-bottom: 0.5rem; }
  .product__align-left .product__title { font-size: 19px; }
  .benefit-pill, .product-benefits.cup .benefit-pill { font-size: 9px; }
  .product-benefits { margin: 0; }
  .product-certificates-block .certificates-grid { overflow-x: auto; overflow-y: hidden; }
  .stock-urgency-box { max-width: 100%; width: 100%; }
}
{% endstyle %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign padding_top = section.settings.padding_top
  if section.settings.product_breadcrumbs
    assign padding_top = padding_top | divided_by: 2
  endif
-%}

<div class="product-section section-padding {{ section.settings.bg }}"
  data-product-handle="{{ product.handle }}"
  data-section-id="{{ section.id }}"
  data-section-type="product"
  data-form-holder
  data-enable-video-looping="{{ section.settings.enable_video_looping }}"
  data-enable-history-state="true"
  style="--PT:{{ section.settings.padding_top }}px;--PB:{{ section.settings.padding_bottom }}px;--IMAGE-SPACING:{{ section.settings.image_spacing }}px;"
>
  {%- liquid
    assign images_settings = section.settings.layout | split: '@'
    assign wrapper_class    = section.settings.width
    assign image_width      = section.settings.image_width
    assign thumbnails       = images_settings[0]
    assign grid_style       = images_settings[1]
    assign data_thumbnails_left = ''

    if thumbnails == 'thumbnails-left'
      assign data_thumbnails_left = 'data-thumbnails-left'
    endif

    assign has_thumbnails_setting = false
    if thumbnails == 'thumbnails-left' or thumbnails == 'thumbnails-below' or section.settings.mobile_layout == 'thumbs'
      assign has_thumbnails_setting = true
    endif

    assign desktop_slideshow_style = 'none'
    if grid_style == 'slides'
      assign desktop_slideshow_style = 'slideshow'
    endif

    if wrapper_class == 'wrapper--none'
      if thumbnails == 'thumbnails-left' or thumbnails == 'thumbnails-below'
        assign wrapper_class = 'wrapper--full'
      endif
    endif

    assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id

    assign product_has_breadcrumbs = false
    if section.settings.product_breadcrumbs_enable and section.settings.product_breadcrumbs_list.count > 0
      assign product_has_breadcrumbs = true
    endif

    assign pad_title = ''
    if section.settings.padding_top < 20 and product_has_breadcrumbs
      assign pad_title = 'push-product-title'
    endif

    case image_width
      when 'half'
        assign product_image_width       = 'medium-up--one-half'
        assign product_description_width = 'medium-up--one-half'
      else
        assign product_image_width       = 'large-up--five-eighths medium--one-half'
        assign product_description_width = 'large-up--three-eighths medium--one-half'
    endcase

    assign has_alt_text_filtered_images = false
    assign alt_text_concat = product.media | map: 'alt' | join: ''
    if alt_text_concat contains '#' and alt_text_concat contains '_'
      assign has_alt_text_filtered_images = true
    endif

    assign first_product_media = product.media[0]

    if has_alt_text_filtered_images
      capture media_list
        render 'order-media', product: product, order: true
      endcapture
      assign media_list = media_list | strip_html | strip | split: ','
      if media_list.size == product.media.size
        assign new_media_position = media_list[0] | minus: 1
        assign first_product_media = product.media[new_media_position]
      endif
    endif
  -%}

  {%- if product_has_breadcrumbs -%}
    {%- capture breadcrumbs_markup -%}
      {%- for bc_collection in section.settings.product_breadcrumbs_list -%}
        <a href="{{ bc_collection.url }}" title="{{ bc_collection.title }}">{{ bc_collection.title }}</a>
       -
      {%- endfor -%}
      <span>{{ product.title | escape }}</span>
    {%- endcapture -%}
  {%- endif -%}

  <div class="product-page">
    <div class="{{ wrapper_class }} {{ pad_title }} product__align-{{ section.settings.align }}">
      <div class="float-grid product-single" {{ data_thumbnails_left }}>

        {%- if product_has_breadcrumbs -%}
          <div class="grid__item one-whole">
            <nav class="breadcrumb{% unless wrapper_class != 'wrapper--none' %} medium-up--hide{% endunless %}" aria-label="breadcrumbs">
              {{ breadcrumbs_markup }}
            </nav>
          </div>
        {%- endif -%}

        <div class="grid__item product__media__wrapper {{ product_image_width }} product__mobile--{{ section.settings.mobile_layout }}">
          <div class="product__grid product__grid--{{ grid_style }} flickity-lock-height"
            data-product-media-gallery
            data-product-slideshow
            data-slideshow-desktop-style="{{ desktop_slideshow_style }}"
            data-slideshow-mobile-style="{{ section.settings.mobile_layout }}"
            {%- unless section.settings.layout contains 'slides' %} data-vertical-images{%- endunless %}
            {%- if first_product_media.aspect_ratio > 0 %}
              style="--default-ratio: {{ 1 | divided_by: first_product_media.aspect_ratio | times: 100 | at_most: 150 }}%"
            {%- endif %}
          >
            {%- if product.media.size > 0 -%}
              {%- for media_item in product.media -%}
                {%- liquid
                  assign media = media_item
                  if has_alt_text_filtered_images and media_list.size == product.media.size
                    assign new_media_position = media_list[forloop.index0] | minus: 1
                    assign media = product.media[new_media_position]
                  endif
                  if forloop.first
                    assign loading_animation = false
                  elsif grid_style == 'slides' and first_product_media.id != media_item.id
                    assign loading_animation = false
                  else
                    assign loading_animation = true
                  endif
                  comment
                    First product image = LCP. Pass eager + high fetchpriority.
                    All other images = lazy + auto priority.
                  endcomment
                  if forloop.first
                    assign media_loading      = 'eager'
                    assign media_fetchpriority = 'high'
                  else
                    assign media_loading      = 'lazy'
                    assign media_fetchpriority = 'auto'
                  endif
                -%}
                {%- liquid
                  assign media_width_pdp = nil
                  if forloop.first
                    assign media_width_pdp = 800
                  else
                    assign media_width_pdp = 600
                  endif
                -%}
                {%- render 'media',
                  media: media,
                  section: section,
                  product: product,
                  loading_animation: loading_animation,
                  loading: media_loading,
                  fetchpriority: media_fetchpriority,
                  width: media_width_pdp
                -%}
              {%- endfor -%}
            {%- else -%}
              <div class="product__image__placeholder"></div>
            {%- endif -%}
          </div>

          {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
          {%- if first_3d_model -%}
            <button class="btn--outline btn--ar" data-shopify-xr
              data-shopify-model3d-id="{{ first_3d_model.id }}"
              data-shopify-title="{{ product.title | strip_html | escape }}"
              data-shopify-xr-hidden>
              {%- render 'icon-media-model' -%}
              <span>{{ 'products.product.view_in_space' | t }}</span>
            </button>
          {%- endif -%}

          {%- if product.media.size > 1 and has_thumbnails_setting -%}
            {%- assign hide_thumbs_desktop = '' -%}
            {%- if thumbnails == 'none' -%}{%- assign hide_thumbs_desktop = 'media__thumb__holder--mobile-only' -%}{%- endif -%}

            <div class="media__thumb__holder {{ hide_thumbs_desktop }}" data-thumbs-holder>
              <button class="media__thumb__button" data-thumbs-arrow-prev>
                {%- render 'icon-core-chevron-up' -%}
                <span class="visually-hidden">{{ 'general.accessibility.previous' | t }}</span>
              </button>

              <div
                {%- if thumbnails == 'thumbnails-left' %} data-product-thumbs-slider{%- endif %}
                data-product-thumbs
                class="media__thumb__wrapper"
              >
                {%- for media_item in product.media -%}
                  {%- assign media = media_item -%}
                  {%- if has_alt_text_filtered_images and media_list.size == product.media.size -%}
                    {%- assign new_media_position = media_list[forloop.index0] | minus: 1 -%}
                    {%- assign media = product.media[new_media_position] -%}
                  {%- endif -%}

                  {%- assign alt_text       = media.alt | strip_html -%}
                  {%- assign alt_text_parts = alt_text | split: '#' -%}
                  {%- assign alt_text_option = '' -%}
                  {%- if alt_text contains '#' and alt_text contains '_' and alt_text_parts.size == 2 -%}
                    {%- assign alt_text_option = alt_text_parts | last | split: ' ' | first -%}
                  {%- endif -%}

                  <div class="media__thumb{%- if forloop.first %} is-activated{%- endif %}"
                    data-slideshow-thumbnail
                    data-aspect-ratio="{% if media.aspect_ratio %}{{ media.aspect_ratio }}{% else %}{{ media.preview_image.aspect_ratio }}{% endif %}"
                    data-media-select="{{ media.id }}"
                    aria-label="{{ alt_text_parts | first | escape }}"
                    data-image-filter="{{ alt_text_option }}"
                  >
                    <img
                      src="{{ media.preview_image.src | image_url: width: 120 }}"
                      alt="{{ alt_text_parts | first | escape }}"
                      width="120"
                      height="120"
                      loading="lazy"
                      decoding="async"
                      class="loading-shimmer"
                    >
                    {%- if media.media_type == 'model' -%}{%- render 'icon-media-model' -%}
                    {%- elsif media.media_type contains 'video' -%}{%- render 'icon-media-video' -%}
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>

              <button class="media__thumb__button" data-thumbs-arrow-next>
                {%- render 'icon-core-chevron-down' -%}
                <span class="visually-hidden">{{ 'general.accessibility.next' | t }}</span>
              </button>
            </div>
          {%- endif -%}
        </div>

        <div class="product__main__content grid__item {{ product_description_width }}">
          <div class="product__inner is-sticky" data-product-form-wrapper>
            {%- if product_has_breadcrumbs -%}
              <nav class="breadcrumb small-down--hide{% unless wrapper_class == 'wrapper--none' %} medium-up--hide{% endunless %}" aria-label="breadcrumbs">
                {{ breadcrumbs_markup }}
              </nav>
            {%- endif -%}

            {%- for block in section.blocks -%}
              {%- case block.type -%}

                {%- when '@app' -%}
                  {%- render block -%}

                {%- when 'title' -%}
                  {%- liquid
                    assign show_save_badge = false
                    assign save_percent = 0
                    if product.compare_at_price > product.price
                      assign difference_amount = product.compare_at_price | minus: product.price
                      assign save_percent = difference_amount | times: 100 | divided_by: product.compare_at_price | round
                      if save_percent > 0
                        assign show_save_badge = true
                      endif
                    endif
                  -%}
                  {%- if product.metafields.custom.best_seller_tag != blank or show_save_badge -%}
                    <div class="tp-inline-badges">
                      {%- if product.metafields.custom.best_seller_tag != blank -%}
                        <span class="tp-badge tp-badge--best tp-badge--pulse">{{ product.metafields.custom.best_seller_tag }}</span>
                      {%- endif -%}
                      {%- if show_save_badge -%}
                        <span class="tp-badge tp-badge--save">Save {{ save_percent }}%</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- render 'product-title', product: product, block: block, section: section -%}

                {%- when 'price' -%}
                  {%- render 'product-price', product: product, block: block, section: section -%}

                {%- when 'product-certificates' -%}
                  <div class="product-certificates-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.heading != blank -%}
                      <h4 class="certificates-heading">{{ block.settings.heading | escape }}</h4>
                    {%- endif -%}
                    <div class="certificates-grid">
                      {%- for i in (1..4) -%}
                        {%- assign cert_img = 'image_' | append: i -%}
                        {%- if block.settings[cert_img] != blank -%}
                          <div class="certificate-item">
                            <img
                              src="{{ block.settings[cert_img] | image_url: width: 160 }}"
                              alt="{{ block.settings.heading | default: 'Certificate' | escape }}"
                              width="80"
                              height="80"
                              loading="lazy"
                              decoding="async"
                            >
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>

                {%- when 'add-buttons' -%}
                  {%- if product.metafields.custom.shipping_free_are_not != blank -%}
                    {%- assign ship_img = product.metafields.custom.shipping_free_are_not -%}
                    <div class="free-shipping-text-product bbbbbbb">
                      <img
                        src="{{ ship_img | image_url: width: 600 }}"
                        alt="Free shipping"
                        width="{{ ship_img.width | at_most: 600 }}"
                        height="auto"
                        loading="lazy"
                        decoding="async"
                      >
                    </div>
                  {%- endif -%}

                  {%- render 'product-buttons', product: product, uniq_id: product_form_id, block: block -%}

                  <!-- Payment Icons -->
                  <div class="payment-icons-wrapper">
                    <p class="payment-title">100% Secure Payment</p>
                    <div class="payment-icons">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/paytm-circle-logo-hd-png-701751694706614zmho56voff.png?v=1771907954" alt="Paytm" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/Google_Pay_Logo.svg?v=1771907953" alt="Google Pay" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/images_1.png?v=1771907953" alt="PhonePe" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/amazon-pay-logo-biggest-online-600nw-2360491029.webp?v=1771907952" alt="Amazon Pay" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/60378.png?v=1771907952" alt="UPI" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/images_2.png?v=1771907952" alt="Visa" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/bhim-app-icon.webp?v=1771907952" alt="BHIM" width="50" height="50" loading="lazy" decoding="async">
                      <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/3__2821_29.jpg?v=1771907953" alt="Mastercard" width="50" height="50" loading="lazy" decoding="async">
                    </div>
                  </div>

                  {%- assign recommended_product = product.metafields.custom.product_recommendation.value -%}
                  {%- if recommended_product != blank -%}
                    <div class="product-recommendation-offer">
                      <div class="recommendation-grid">
                        <div class="recommended-item">
                          <a href="{{ recommended_product.url }}">
                            {%- if recommended_product.featured_image != blank -%}
                              <img
                                src="{{ recommended_product.featured_image | image_url: width: 300 }}"
                                alt="{{ recommended_product.title | escape }}"
                                width="150"
                                height="150"
                                loading="lazy"
                                decoding="async"
                              >
                            {%- endif -%}
                            <div>
                              <h3>🔥 Buy 2 Get 1 Free (Exclusive Offer)</h3>
