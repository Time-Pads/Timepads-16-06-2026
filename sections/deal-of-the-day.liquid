{% style %}
/* ── Deal of the Day ── */
.deal-of-day-section {
  background: linear-gradient(135deg,#fee 0%,#fee 100%);
  overflow: hidden;
}

.deal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 40px;
}

.deal-header h2.kicker-flourished {
  text-align: center;
  margin: 2rem auto 0;
}

.deal-products-wrapper {
  position: relative;
  padding: 0;
  width: 95%;
  margin: auto;
  margin-bottom: 3rem;
}

.deal-products-container {
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.deal-products-container::-webkit-scrollbar {
  display: none;
}

.deal-products-slider {
  display: flex;
  gap: 20px;
}

.deal-product-item {
  flex: 0 0 calc(25% - 15px);
  min-width: 0;
  scroll-snap-align: start;
}

.deal-products-container .sale-badge { width: 120px; }
.deal-products-container product-grid-item.product-grid-item.group\/product-grid-item { border: none; }
.deal-product-item .free-shipping-text-product { margin-top: 1rem; }

.deal-of-day-section .product__grid__title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Tablet */
@media (max-width: 989px) {
  .deal-product-item { flex: 0 0 calc(33.333% - 14px); }
}

/* Mobile */
@media (max-width: 749px) {
  .deal-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .deal-header h2.kicker-flourished {
    font-size: 20px !important;
    font-weight: 800 !important;
    text-transform: capitalize;
    margin-bottom: 0;
    padding-bottom: 0;
    width: 100%;
  }

  .deal-products-slider {
    gap: 15px;
    padding-bottom: 1.5rem;
  }

  .deal-product-item {
    flex: 0 0 75%;
    min-width: 0;
    scroll-snap-align: start;
  }

  .deal-products-wrapper { padding: 0; }

  .deal-of-day-section .free-shipping-text-product img {
    width: 60%;
    object-fit: contain;
  }
}

@media (min-width: 750px) {
  .deal-header h2 { font-size: 26px !important; }
}
#shopify-section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px !important;
  padding-bottom: {{ section.settings.padding_bottom }}px !important;
}
@media (max-width: 768px) {
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
  }
}
{% endstyle %}

{%- capture lazy_load_section -%}
  {%- render 'lazy-load-section-validations' -%}
{%- endcapture -%}

{%- if lazy_load_section != blank -%}
  <lazy-section>
{%- endif -%}

{%- if lazy_load_section == blank -%}
<div class="deal-of-day-section color-{{ section.settings.color_scheme }} gradient" data-section-id="{{ section.id }}">
  <div class="page-width">

    <div class="deal-header">
      <h2 class="kicker-flourished">Limited-Time Deals for You</h2>
    </div>

    <div class="deal-products-wrapper">
      <div class="deal-products-container">
        <div class="deal-products-slider">
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <div class="deal-product-item" {{ block.shopify_attributes }}>
                {%- render 'product-card-home-page',
                  product: product,
                  placeholder: false,
                  columns_desktop: section.settings.columns_desktop,
                  columns_mobile: section.settings.columns_mobile,
                  show_discount_badge: true,
                  show_limited_badge: section.settings.show_limited_badge,
                  loading: 'lazy'
                -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>
{%- else -%}
  <div class="deal-of-day-section color-{{ section.settings.color_scheme }} gradient" style="min-height: 400px; display: flex; align-items: center; justify-content: center;">
    <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg" width="66" height="66">
      <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
    </svg>
  </div>
{%- endif -%}

{%- if lazy_load_section != blank -%}
  </lazy-section>
{%- endif -%}


{% schema %}
{
  "name": "Deal of the Day",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_limited_badge",
      "label": "Show 'Limited Time Offer' badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "1",
      "label": "Number of columns on mobile"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Deal of the Day",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
