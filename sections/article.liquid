<script>
const form = document.getElementById('commentForm');
const btn = document.getElementById('submitBtn');

const fields = [
  document.getElementById('CommentAuthor'),
  document.getElementById('CommentEmail'),
  document.getElementById('CommentBody'),
  document.getElementById('privacyPolicy')
];

// Enable/Disable button
function checkForm() {
  let valid = true;

  fields.forEach(field => {
    if (field.type === "checkbox") {
      if (!field.checked) valid = false;
    } else {
      if (!field.value.trim()) valid = false;
    }
  });

  btn.disabled = !valid;
}

fields.forEach(field => {
  field.addEventListener('input', checkForm);
  field.addEventListener('change', checkForm);
});

// Formspree trigger
form.addEventListener('submit', function() {

  const formData = new FormData();
  formData.append("name", document.getElementById('CommentAuthor').value);
  formData.append("email", document.getElementById('CommentEmail').value);
  formData.append("phone", document.getElementById('CommentPhone').value);
  formData.append("message", document.getElementById('CommentBody').value);

  fetch("https://formspree.io/f/xdapqekb", {
    method: "POST",
    body: formData,
    headers: { 'Accept': 'application/json' }
  });

});
</script>

