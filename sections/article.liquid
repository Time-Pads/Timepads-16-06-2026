    </button>

  </div>
</div>

<style>

.tp-simple-share{
  margin:24px 0;
  padding:16px 18px;

  display:flex;
  align-items:center;
  justify-content:space-between;

  border-radius:18px;
  background:#fff;

  border:1px solid #ebe6df;
  box-shadow:0 6px 20px rgba(0,0,0,.04);
}

.tp-simple-share__title{
  margin:0;

  font-size:15px;
  font-weight:600;
  color:#1f1f1f;
}

.tp-simple-share__icons{
  display:flex;
  align-items:center;
  gap:12px;
}

.tp-simple-share__icon{
  width:44px;
  height:44px;

  border:none;
  cursor:pointer;

  border-radius:50%;

  display:flex;
  align-items:center;
  justify-content:center;

  transition:0.25s ease;
}

.tp-simple-share__icon:hover{
  transform:translateY(-2px) scale(1.05);
}

.tp-simple-share__icon img{
  width:22px;
  height:22px;
  object-fit:contain;
}

.tp-simple-share__icon svg{
  width:20px;
  height:20px;
}

/* colors */

.tp-simple-share__icon--whatsapp{
  background:#e9fff1;
}

.tp-simple-share__icon--facebook{
  background:#eef4ff;
}

.tp-simple-share__icon--share{
  background:#f5f5f5;
  color:#222;
}

/* mobile */

@media(max-width:768px){

  .tp-simple-share{
    padding:14px 16px;
    border-radius:16px;
            width: 90%;
        margin: auto;
        margin-top: 1rem;
  }

  .tp-simple-share__title{
    font-size:14px;
  }

  .tp-simple-share__icon{
    width:40px;
    height:40px;
  }

  .tp-simple-share__icon img{
    width:20px;
    height:20px;
  }
}

</style>

<script>

document.addEventListener("DOMContentLoaded", () => {

  const shareBtn = document.getElementById("tpNativeShare");

  if (!shareBtn) return;

  shareBtn.addEventListener("click", async () => {

    const shareData = {
      title: document.title,
      text: "{{ article.title }}",
      url: window.location.href
    };

    if (navigator.share) {

      try {
        await navigator.share(shareData);
      } catch (err) {
        console.log("Share cancelled");
      }

    } else {

      navigator.clipboard.writeText(window.location.href);

      alert("Link copied successfully");

    }

  });

});

</script>

          <div class="blog__sidebar">
            <h2 class="blog__sidebar__title">{{ blog.title }}</h2>
            <a class="blog__rss" href="{{ blog.url }}.atom" title="{{ shop.name }} RSS" target="_blank">

              <span class="visually-hidden">RSS</span>
            </a>
            <hr class="hr--small">
            {% if blog.all_tags != blank and section.settings.sidebar_tags %}
              <p class="accent-size-3 strong">{{ 'blogs.article.tags' | t }}</p>

              <div class="blog__tags">
                {% if blog.all_tags.size > 1 %}
                  <div class="blog__tags-wrapper">
                    {% for tag in blog.all_tags %}
                    <a class="btn--soft btn--primary blog__tag" href="{% unless routes.root_url == '/' %}{{ routes.root_url }}{% endunless %}/blogs/{{ blog.handle }}/tagged/{{ tag | handleize }}">{{ tag }}</a>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>

              <div class="pt-r8"></div>
            {% endif %}
            {% if section.settings.recent %}
              {% assign counter = 0 %}
              {% assign article_limit = 2 %}
              {% assign current_article = article %}
              {% for article in blog.articles %}
                {% unless article.handle == current_article.handle %}
                  {% render 'article-grid-item',
                    article: article,
                    wh_ratio: section.settings.wh_ratio,
                    show_author: section.settings.show_author,
                    show_preview: section.settings.show_preview,
                    show_link: section.settings.show_link,
                    show_tags: section.settings.show_tags,
                    show_date: section.settings.show_date,
                    section_columns: 3,
                    section_width: section.settings.width
                  %}
                  {% assign counter = counter | plus: 1 %}
                  {% if counter == article_limit %}
                    {% break %}
                  {% endif %}
                {% endunless %}
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Article",
    "articleBody": {{ article.content | strip_html | json }},
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ shop.url | append: page.url | json }}
    },
    "headline": {{ article.title | json }},
    {% if article.excerpt != blank %}
      "description": {{ article.excerpt | strip_html | json }},
    {% endif %}
    {% if article.image %}
      {% assign image_size = article.image.width | append: 'x' %}
      "image": [
        {{ article | img_url: image_size | prepend: "https:" | json }}
      ],
    {% endif %}
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
  </script>

