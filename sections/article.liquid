<!-- /sections/article.liquid -->
{% assign number_of_comments = article.comments_count %}
{% assign show_featured_image = section.settings.show_featured_image %}

{% comment %}
  If a comment was just submitted and it has no blank fields, we have an extra comment to count.
{% endcomment %}
{% if comment and comment.created_at %}
  {% assign number_of_comments = article.comments_count | plus: 1 %}
{% endif %}

{% assign sidebar_enable = false %}
{% if article.tags != blank and section.settings.sidebar_tags %}
  {% assign sidebar_enable = true %}
{% elsif section.settings.recent %}
  {% assign sidebar_enable = true %}
{% endif %}


{% assign blog_grid = 'medium-up--two-thirds medium-up--push-one-sixth' %}
{% if sidebar_enable %}
  {% assign blog_grid = 'medium-up--two-thirds' %}
{% endif %}


<div class="{{ section.settings.color_bg }}"
  data-section-id="{{ section.id }}"
  data-section-type="article"
  style="--PT: {{ section.settings.padding_top }}px; --PB: {{ section.settings.padding_bottom }}px;">
  {%- if article.image and show_featured_image -%}
    <div data-overlay-header>
      {%- assign alt = article.image.alt | default: 'Banner Image' -%}
      {% render 'image-parallax', img_object: article.image, frame_height_class: section.settings.image_height, bg_position: section.settings.bg_position, preload: true, loading: 'eager', fetchpriority: 'high', alt: alt %}
    </div>
  {%- endif -%}

<!-- Mobile Share Bar -->

<!-- SHARE BUTTONS -->

<div class="tp-simple-share desktop-hide">

  <p class="tp-simple-share__title">
    Share this blog
  </p>

  <div class="tp-simple-share__icons">

    <!-- WhatsApp -->
    <a
      href="https://wa.me/?text={{ article.title }} - {{ shop.url }}{{ article.url }}"
      target="_blank"
      class="tp-simple-share__icon tp-simple-share__icon--whatsapp"
      aria-label="WhatsApp"
    >
      <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" />
    </a>

    <!-- Facebook -->
    <a
      href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}"
      target="_blank"
      class="tp-simple-share__icon tp-simple-share__icon--facebook"
      aria-label="Facebook"
    >
      <img src="https://upload.wikimedia.org/wikipedia/commons/1/1b/Facebook_icon.svg" alt="Facebook" />
    </a>

    <!-- Native Share -->
    <button
      type="button"
      class="tp-simple-share__icon tp-simple-share__icon--share"
      id="tpNativeShare"
      aria-label="Share"
    >
      <svg viewBox="0 0 24 24" fill="none">
        <path
          d="M12 16V4M12 4L7 9M12 4L17 9"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M5 15V18C5 19.1046 5.89543 20 7 20H17C18.1046 20 19 19.1046 19 18V15"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </button>

  </div>
</div>

<style>

.tp-simple-share{
  margin:24px 0;
  padding:16px 18px;

  display:flex;
  align-items:center;
  justify-content:space-between;

  border-radius:18px;
  background:#fff;
  width: 90%;
  margin: auto;
  border:1px solid #ebe6df;
  box-shadow:0 6px 20px rgba(0,0,0,.04);
}

.tp-simple-share__title{
  margin:0;

  font-size:15px;
  font-weight:600;
  color:#1f1f1f;
}

.tp-simple-share__icons{
  display:flex;
  align-items:center;
  gap:12px;
}

.tp-simple-share__icon{
  width:44px;
  height:44px;

  border:none;
  cursor:pointer;

  border-radius:50%;

  display:flex;
  align-items:center;
  justify-content:center;

  transition:0.25s ease;
}

.tp-simple-share__icon:hover{
  transform:translateY(-2px) scale(1.05);
}

.tp-simple-share__icon img{
  width:22px;
  height:22px;
  object-fit:contain;
}

.tp-simple-share__icon svg{
  width:20px;
  height:20px;
}

/* colors */

.tp-simple-share__icon--whatsapp{
  background:#e9fff1;
}

.tp-simple-share__icon--facebook{
  background:#eef4ff;
}

.tp-simple-share__icon--share{
  background:#f5f5f5;
  color:#222;
}

@media only screen and (min-width: 768px) {
  .desktop-hide{
    display: none;
  }
}

/* mobile */

@media(max-width:768px){

  .tp-simple-share{
    padding:14px 16px;
    border-radius:16px;
            margin: auto;
        margin-top: 1rem;
  }
  

  .tp-simple-share__title{
    font-size:14px;
  }

  .tp-simple-share__icon{
    width:40px;
    height:40px;
  }

  .tp-simple-share__icon img{
    width:20px;
    height:20px;
  }
}

</style>

<script>

document.addEventListener("DOMContentLoaded", () => {

  const shareBtn = document.getElementById("tpNativeShare");

  if (!shareBtn) return;

  shareBtn.addEventListener("click", async () => {

    const shareData = {
      title: document.title,
      text: "{{ article.title }}",
      url: window.location.href
    };

    if (navigator.share) {

      try {
        await navigator.share(shareData);
      } catch (err) {
        console.log("Share cancelled");
      }

    } else {

      navigator.clipboard.writeText(window.location.href);

      alert("Link copied successfully");

    }

  });

});

</script>


  <div class="{{ section.settings.width }} section-padding">
    <div class="float-grid">
      <article class="grid__item {{ blog_grid }}">
        <div class="blog__article{% if article.image and show_featured_image %} blog__article--over-image{% endif %}">
          <header>
            <h1 class="blog__article__title heading-size-9">{{ article.title }}</h1>
            {% if section.settings.blog_show_meta %}
              {% capture author %}<span class="strong">{{ article.author }}</span>{% endcapture %}
              {% capture date %}<time>{{ article.published_at | date: format: 'month_day_year' }}</time>{% endcapture %}
              <p class="blog__article--light">{{ 'blogs.article.author_on_date_html' | t: author: author, date: date }}</p>
            {% endif %}
          </header>

          <div class="blog__article__content rte">
            {{ article.content }}
          </div>

          {% if section.settings.tags %}
            {% render 'tags-article', article: article %}
          {% endif %}
          {% if section.settings.social %}
            <div class="text-center">
              {% render 'share' article: article, label: section.settings.share_label %}
            </div>
          {% endif %}
        </div>

        {% if blog.next_article or blog.previous_article %}
          <p class="clearfix">
            {% if blog.previous_article %}
              <span class="left">
                <a href="{{ blog.previous_article }}" class="btn--soft">
                  &larr; {{ 'blogs.article.older_post' | t }}
                </a>
              </span>
            {% endif %}
            {% if blog.next_article %}
              <span class="right">
                <a href="{{ blog.next_article }}" class="btn--soft">
                  {{ 'blogs.article.newer_post' | t }} &rarr;
                </a>
              </span>
            {% endif %}
          </p>
        {% endif %}

        {% if blog.comments_enabled? %}
          {% paginate article.comments by 10 %}
            {% comment %}
              #Comments is required, it is used as an anchor link by Shopify.
            {% endcomment %}
            <div class="blog__comments mt-r11" id="Comments">

              {% if article.comments_count > 0 %}
                <p class="kicker-flourished text-left">{{ 'blogs.comments.comments_with_count' | t: count: number_of_comments }}</p>
              {% endif %}

              {% if comment and comment.created_at %}
                <p class="note form-success">
                  {% if blog.moderated? %}
                    {{ 'blogs.comments.success_moderated' | t }}
                  {% else %}
                    {{ 'blogs.comments.success' | t }}
                  {% endif %}
                </p>
              {% endif %}

              {% if number_of_comments > 0 %}
                <ul>
                  {% comment %}
                    If a comment was just submitted with no blank field, show it.
                  {% endcomment %}
                  {% if comment and comment.created_at and blog.moderated? %}
                    <li id="{{ comment.id }}" class="comment first{% if article.comments_count == 0 %} last{% endif %}">
                        {% render 'comment', comment: comment %}
                    </li>
                  {% endif %}

                  {% comment %}
                    Showing the rest of the comments.
                  {% endcomment %}
                  {% for comment in article.comments %}
                    <li id="{{ comment.id }}" class="comment{% unless number_of_comments > article.comments_count %}{% if forloop.first %} first{% endif %}{% endunless %}{% if forloop.last %} last {% endif %}">
                        {% render 'comment', comment: comment %}
                    </li>
                  {% endfor %}
                </ul>

                {% if paginate.pages > 1 %}
                  <hr class="hr--clear">
                  <div class="text-center">
                    {% render 'pagination-custom', paginate: paginate %}
                  </div>
                {% endif %}

              {% endif %}


