{%- style -%}

  @media screen and (min-width: 750px){
  .section-{{ section.id }}-padding{
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  }
  @media screen and (max-width: 749px){
  .section-{{ section.id }}-padding{
  padding-top: {{ section.settings.mpadding_top }}px;
  padding-bottom: {{ section.settings.mpadding_bottom }}px;
  }
  }
  
  .collection-metafield__section {
  display: flex;
  gap: 10px;
  overflow: scroll;
  scrollbar-width: thin; /* For Firefox */
  scrollbar-color: #008ecc transparent; /* Scrollbar color for Firefox */
  }
  
  /* WebKit-based browsers (Chrome, Safari, Edge) */
  .collection-metafield__section::-webkit-scrollbar {
  width: 0.5px;
  height: 0.5px;
  }
  
  .collection-metafield__section::-webkit-scrollbar-thumb {
  background-color: #008ecc; /* Change scrollbar thumb color */
  border-radius: 10px;
  }
  
  .collection-metafield__section::-webkit-scrollbar-track {
  background-color: transparent; /* Scrollbar track color */
  }
  
  .collection-metafield__section .grid-item{
  flex: 0 0 12%;
  align-items: stretch;
  display: flex;
  margin-bottom: 10px;
  padding-left: 7px;
  padding-right: 7px;
  }
  .collections-section__image{
  text-align: center;
  }
  .collections-section__image img{
  max-width: 100%;
  }
  .collection-item__title{
  display: block;
  font-weight: 700;
  margin-top: 5px;
  padding: 0 7%;
  }
  .collection-metafield__section a{
  text-decoration: none;
  color: black;
  }
  .collection-item__title {
  font-size: 10px;
  }
  
  @media only screen and (max-width:767px){
  .collection-metafield__section .grid-item {
  flex: 0 0 37%;
  }
  }
  {%- endstyle -%}
  
  {% assign meta = collection.metafields.custom.subcollection.value %}
  {% if collection.metafields.custom.subcollection != blank %}
  <div class="page-width collection__metafield--section section-{{ section.id  }}-padding">
  <div class="collection-metafield__section">
  {% for list in meta %}
  <div class="grid-item">
  <a href="{{ list.url }}">
  <div class="collections-section__image">
  {% assign subcollection = collections[list.handle] %}
  
            <!-- Assuming each subcollection has its own circular_image metafield -->
            {% assign subcollection_metaimage = subcollection.metafields.custom.circular_collection.value %}
  
            <!-- 1. Check if the collection image is available -->
            {% assign preview_image = subcollection_metaimage %}
            {% if preview_image == blank and subcollection.image != blank %}
              {% assign preview_image = subcollection.image %}
            {% endif %}
            {% if preview_image == blank and subcollection.products.size > 0 %}
              {% assign preview_image = subcollection.products.first.featured_image %}
            {% endif %}

            {% if preview_image != blank %}
              {{
                preview_image
                | image_url: width: 360
                | image_tag:
                  alt: list.title,
                  widths: '120, 180, 240, 360',
                  sizes: '(max-width: 767px) 37vw, 12vw',
                  loading: 'lazy',
                  fetchpriority: 'low'
              }}
            {% endif %}
  
            <div class="collection-item__title">{{ list.title }}</div>
          </div>
        </a>
      </div>
    {% endfor %}
  </div>

  </div>
  {% endif %}
  
  {% schema %}
  {
  "name": "collections metafield",
  "settings": [
  {
  "type":"text",
  "id":"heading",
  "label":"Heading"
  },
  {
  "type": "header",
  "content": "padding"
  },
  {
  "type": "range",
  "id": "padding_top",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "padding_top",
  "default": 36
  },
  {
  "type": "range",
  "id": "padding_bottom",
  "min": 0,
  "max": 100,
  "step": 4,
  "unit": "px",
  "label": "padding_bottom",
  "default": 36
  },
  {
  "type": "range",
  "id": "mpadding_top",
  "min": 0,
  "max": 100,
  "step": 1,
  "unit": "px",
  "label": "Mobile Padding Top",
  "default": 100
  },
  {
  "type": "range",
  "id": "mpadding_bottom",
  "min": 0,
  "max": 100,
  "step": 1,
  "unit": "px",
  "label": "Mobile Padding Bottom",
  "default": 100
  }
  
  ],
  "presets":[{
  "name": "collections metafield"
  }]
  }
  {% endschema %}
