<div class="page-width wtr-container section-id-{{ section.id }}">
    <div class="main-container-way-to-earn">
    <h3>{{ section.settings.heading }}</h3>
    <p>{{ section.settings.Sub_heading }}</p>
    </div>
    <div class="main-container-wrapper-wtr">
 {% for block in section.blocks %}
<div class="way-to-earn-container">
<div class="way-to-earn-image-container">
    {% render 'responsive-picture' 
    forloop: forloop,
    desktopImage: block.settings.image, 
    mobileImage: block.settings.image,
    img-class: 'tw-w-full tw-max-h-[60rem]'
  %}
</div>
<div class="way-to-earn-text-container">
    <h4>{{ block.settings.heading_content }}</h4>
    <p>{{ block.settings.sub_heading_content }}</p>
    <p class="starts-text-wtr">{{ block.settings.sub_heading_content_start }}</p>
</div>
</div>
 {% endfor %}
    </div>

</div>

{% style %} 
.way-to-earn-container{
    border: 1px solid #ddd;
}
.page-width.wtr-container{
    padding: 40px 30px;
}
.section-id-{{ section.id }}{
    background-color: {{ section.settings.Bg_color }};
}

.main-container-way-to-earn{
    text-align: center;
    margin-bottom: 3rem;
}
.main-container-wrapper-wtr{
    width: 80%;
    margin: auto;
}
.way-to-earn-container{
    display: flex;
    border-radius: 5px;
    flex: 0 0 30%;
    background: white;
    padding: 15px 20px;
    align-items: center;
    gap: 1rem;
}
.way-to-earn-text-container p{
    font-size: 12px;
}
.way-to-earn-text-container h4{
 font-size: 16px;
}
.main-container-wrapper-wtr{
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    justify-content: center;
}
.sub_heading_content_start{

}
@media only screen and (max-width: 767px){
    .way-to-earn-container {
    flex: 0 0 100%;
    }
    .main-container-wrapper-wtr{
        width: 100%;
        row-gap: 1rem;
    }
    
}
{% endstyle %}

{% schema %}
{
    "name": "Way To Redeem",
    "settings": [
    {
      "type": "color",
      "id": "Bg_color",
      "label": "Background Color"
    },
    {
    "type":"text",
    "id":"heading",
    "label":"Heading"
    },
    {
    "type":"text",
    "id":"Sub_heading",
    "label":"Sub Heading"
    },
    {
    "type": "header",
    "content": "padding"
    },
    {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 4,
    "unit": "px",
    "label": "padding_top",
    "default": 36
    },
    {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 4,
    "unit": "px",
    "label": "padding_bottom",
    "default": 36
    },
    {
    "type": "range",
    "id": "mpadding_top",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Mobile Padding Top",
    "default": 100
    },
    {
    "type": "range",
    "id": "mpadding_bottom",
    "min": 0,
    "max": 100,
    "step": 1,
    "unit": "px",
    "label": "Mobile Padding Bottom",
    "default": 100
    }
    ],
    "blocks": [
    {
      "type": "blocks",
      "name": "Blocks",
      "settings": [
        {
          "type": "image_picker",
          "label": "image",
          "id": "image",
          "info": "Recommended 690 x 880px"
        },
        {
          "type": "text",
          "id": "heading_content",
          "label": "Heading",
          "default": "Content Tittle"
        },
        {
          "type": "text",
          "id": "sub_heading_content",
          "label": "Content text"
        },
        {
            "type": "text",
          "id": "sub_heading_content_start",
          "label": "Start with text" 
        }
      ]
    }
  ],
    "presets":[{
    "name": "Way To Redeem"
    }]
    }

{% endschema %}