{% stylesheet %}
.trending-wrapper {
  width: 95%;
  margin: auto;
}

.trending-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0px;
  justify-content: center;
}


.trending-header h2 {
  font-size: 26px !important;
  font-weight: 800 !important;
  margin: 0;
}

.trending-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.trending-card {
  display: flex;
  background: #fff8ec;
  border-radius: 16px;
  padding: 15px;
  align-items: center;
  gap: 15px;
  min-height: 115px;
  text-decoration: none;
  transition: transform 0.2s ease-in-out;
}

.trending-card:hover {
  transform: translateY(-3px);
}

.trending-image {
  width: 85px;
  height: 85px;
  border-radius: 12px;
  overflow: hidden;
  flex-shrink: 0;
  aspect-ratio: 1;
}

.trending-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.trending-info { flex: 1; }

.trending-vendor {
  font-size: 12px;
  color: #727272;
  letter-spacing: 0.5px;
  font-weight: 600;
  margin-bottom: 3px;
  text-transform: uppercase;
}

.trending-title {
  font-size: 16px;
  font-weight: 600;
  color: #1d1d1d;
  margin-bottom: 5px;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.trending-price {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 700;
  color: #d12b2b;
}

.trending-compare {
  font-size: 14px;
  color: #777;
  text-decoration: line-through;
}

.trending-arrow {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid #dcdcdc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trending-arrow svg {
  width: 20px;
  height: 20px;
}

@media (max-width: 989px) {
  .trending-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 749px) {
  .trending-grid { grid-template-columns: 1fr; }
  .trending-card { padding: 12px; min-height: 100px; }
  .trending-title { font-size: 14px; }
  .trending-vendor { font-size: 7px; }
}
{% endstylesheet %}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
  }
{% endstyle %}


{%- comment -%} Cache arrow SVG once — reused per card via Liquid variable {%- endcomment -%}
{%- capture arrow_svg -%}
  <div class="trending-arrow" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14"/><path d="M13 18l6-6-6-6"/>
    </svg>
  </div>
{%- endcapture -%}

<div class="page-width trending-wrapper" data-section-id="{{ section.id }}">

  <div class="trending-header">
    {%- if section.settings.heading != blank -%}
      <h2 class="kicker-flourished mb-r11">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.show_all_link and section.settings.all_link != blank -%}
      <a href="{{ section.settings.all_link }}" class="link">Shop All →</a>
    {%- endif -%}
  </div>

  <div class="trending-grid">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      {%- if product != blank and product.featured_image != blank -%}

        {%- assign img     = product.featured_image -%}
        {%- assign img_w   = img.width | at_most: 200 -%}
        {%- assign img_w2x = img_w | times: 2 | at_most: img.width -%}
        <a
          href="{{ product.url }}"
          class="trending-card"
          {{ block.shopify_attributes }}
          aria-label="{{ product.title | escape }}"
        >
          <div class="trending-image">
            <img
              src="{{ img | image_url: width: img_w }}"
              srcset="{{ img | image_url: width: img_w }} 1x, {{ img | image_url: width: img_w2x }} 2x"
              alt="{{ img.alt | default: product.title | escape }}"
              width="85"
              height="85"
              loading="lazy"
              decoding="async"
            >
          </div>

          <div class="trending-info">
            {%- if product.vendor != blank -%}
              <div class="trending-vendor">{{ product.vendor }}</div>
            {%- endif -%}
            <div class="trending-title">{{ product.title | escape }}</div>
            <div class="trending-price">
              <span>{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="trending-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>

          {{ arrow_svg }}

        </a>

      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Trending This Week",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Trending This Week"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Show 'Shop All Products' Link",
      "default": true
    },
    {
      "type": "url",
      "id": "all_link",
      "label": "Shop All Products URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom mobile",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trending This Week",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}
