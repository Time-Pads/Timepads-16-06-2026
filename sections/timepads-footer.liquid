{% comment %}
  TIMEPADS Footer Section
  Shopify Liquid + CSS — Desktop & Mobile Responsive
  Matches: Dark brown background, orange accents, collapsible mobile accordion
{% endcomment %}

<style>
  /* ─── Reset & Variables ─────────────────────────── */
  :root {
    --tp-bg:           #f6ead7;
    --tp-bg-card:     #f6ead7;
    --tp-border:rgb(4, 4, 3);
    --tp-orange:       #e8622a;
    --tp-orange-light: #f07040;
    --tp-gold:         #c8733a;
    --tp-text:         #000000;
    --tp-text-muted:   #000000;
    --tp-white:        #000000;
    --tp-green:        #2ecc71;
    --tp-green-dark:   #27ae60;
    --tp-radius:       999px;
    --tp-radius-card:  12px;
    --tp-font:         'DM Sans', 'Segoe UI', sans-serif;
  }

  #timepads-footer * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #timepads-footer {
    background-color: var(--tp-bg);
    font-family: var(--tp-font);
    color: var(--tp-text);
    border-top: 2px solid var(--tp-orange);
  }

  /* ─── Top Border Accent ─────────────────────────── */
  #timepads-footer .tp-top-bar {
    height: 3px;
    background: linear-gradient(90deg, var(--tp-orange), #ff9a5c, var(--tp-orange));
  }

  /* ─── Main Footer Body ──────────────────────────── */
  #timepads-footer .tp-footer-main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 48px 40px;
    display: grid;
    grid-template-columns: 320px 1fr 1fr 1fr 1fr;
    gap: 40px;
  }

  /* ─── Brand Column ──────────────────────────────── */
  #timepads-footer .tp-brand h2 {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--tp-gold);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  #timepads-footer .tp-brand p {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--tp-text);
    margin-bottom: 28px;
    max-width: 260px;
  }

  /* ─── Buttons ───────────────────────────────────── */
  #timepads-footer .tp-btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tp-green);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 22px;
    border-radius: var(--tp-radius);
    text-decoration: none;
    margin-bottom: 14px;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  #timepads-footer .tp-btn-whatsapp:hover {
    background: var(--tp-green-dark);
    transform: translateY(-1px);
  }
  #timepads-footer .tp-btn-whatsapp svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  #timepads-footer .tp-btn-period {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--tp-bg-card);
    border: 1.5px solid var(--tp-border);
    color: var(--tp-white);
    font-size: 14px;
    font-weight: 500;
    padding: 14px 20px;
    border-radius: var(--tp-radius-card);
    text-decoration: none;
    margin-bottom: 28px;
    transition: border-color 0.2s, background 0.2s;
  }
  #timepads-footer .tp-btn-period:hover {
    border-color: var(--tp-orange);
  }
  #timepads-footer .tp-btn-period .tp-period-icon {
    width: 34px;
    height: 34px;
    background: var(--tp-orange);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  #timepads-footer .tp-btn-period .tp-period-icon svg {
    width: 16px;
    height: 16px;
    color: #fff;
  }
  #timepads-footer .tp-btn-period .tp-period-text {
    display: flex;
    flex-direction: column;
  }
  #timepads-footer .tp-btn-period .tp-period-text span:first-child {
    font-weight: 600;
    font-size: 14px;
    color: black;
  }
  #timepads-footer .tp-btn-period .tp-period-text span:last-child {
    font-size: 11.5px;
    color: var(--tp-text-muted);
    margin-top: 2px;
  }

  /* ─── Social Icons ──────────────────────────────── */
  #timepads-footer .tp-socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  #timepads-footer .tp-socials a {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1.5px solid var(--tp-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tp-text);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  #timepads-footer .tp-socials a:hover {
    border-color: var(--tp-orange);
    color: var(--tp-orange);
    background: rgba(232,98,42,0.08);
  }
  #timepads-footer .tp-socials svg {
    width: 15px;
    height: 15px;
  }

  /* ─── Nav Columns ───────────────────────────────── */
  #timepads-footer .tp-nav-col h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--tp-orange);
    margin-bottom: 22px;
  }

  #timepads-footer .tp-nav-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  #timepads-footer .tp-nav-col ul li a {
    font-size: 13.5px;
    color: var(--tp-text);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    position: relative;
    z-index: 0;
    padding: 2px 10px 2px 0;
    transition: color 0.22s ease, padding-left 0.22s ease;
  }
  #timepads-footer .tp-nav-col ul li a::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: #e8845f;
    z-index: -1;
    transition: width 0.22s cubic-bezier(.4, 0, .2, 1);
  }
  #timepads-footer .tp-nav-col ul li a:hover {
    color: #000;
    padding-left: 10px;
  }
  #timepads-footer .tp-nav-col ul li a:hover::before {
    width: 100%;
  }

  /* Badges */
  #timepads-footer .tp-badge {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
  }
  #timepads-footer .tp-badge-hiring {
    background: var(--tp-orange);
    color: #fff;
  }
  #timepads-footer .tp-badge-new {
    background: var(--tp-orange);
    color: #fff;
  }

  /* ─── Contact Column ────────────────────────────── */
  #timepads-footer .tp-contact-times {
    font-size: 13px;
    line-height: 1.9;
    color: var(--tp-text);
    margin-bottom: 18px;
  }

  #timepads-footer .tp-contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--tp-text);
    text-decoration: none;
    font-size: 13.5px;
    margin-bottom: 12px;
    transition: color 0.2s;
  }
  #timepads-footer .tp-contact-link:hover {
    color: black;
    font-weight: 400;
  }
  #timepads-footer .tp-contact-link .tp-icon-wrap {
    width: 36px;
    height: 36px;
    background: var(--tp-bg-card);
    border: 1.5px solid var(--tp-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  #timepads-footer .tp-contact-link .tp-icon-wrap svg {
    width: 15px;
    height: 15px;
    color: var(--tp-orange);
  }

  /* Desktop: socials in contact column */
  #timepads-footer .tp-contact-socials {
    margin-top: 20px;
  }

  /* ─── Partners Bar ──────────────────────────────── */
  #timepads-footer .tp-partners {
    border-top: 1px solid var(--tp-border);
    padding: 22px 48px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
  }
  #timepads-footer .tp-partners-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--tp-text-muted);
    min-width: 120px;
    margin-right: 20px;
    padding-right: 20px;
    border-right: 1px solid var(--tp-border);
  }
  #timepads-footer .tp-partners-list {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  #timepads-footer .tp-partner-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1.5px solid var(--tp-border);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 13px;
    color: var(--tp-text);
    font-weight: 500;
  }
  #timepads-footer .tp-partner-chip::before {
    content: '';
    width: 7px;
    height: 7px;
    background: var(--tp-orange);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ─── Bottom Bar ────────────────────────────────── */
  #timepads-footer .tp-bottom-bar {
    border-top: 1px solid var(--tp-border);
    padding: 18px 48px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  #timepads-footer .tp-copyright {
    font-size: 12px;
    color: var(--tp-text-muted);
  }
  #timepads-footer .tp-bottom-links {
    display: flex;
    gap: 24px;
    list-style: none;
  }
  #timepads-footer .tp-bottom-links a {
    font-size: 12px;
    color: var(--tp-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  #timepads-footer .tp-bottom-links a:hover {
  color: black;
  }

  @media (min-width: 768px) and (max-width: 1200px) {
    #timepads-footer .tp-footer-main {
      grid-template-columns: 1fr 1fr 1fr;
      padding: 60px 30px 40px;
    }


}


  /* ════════════════════════════════════════════════
     MOBILE — Accordion Style (≤ 768px)
  ════════════════════════════════════════════════ */
  @media (max-width: 768px) {

    #timepads-footer .tp-footer-main {
      grid-template-columns: 1fr;
      padding: 36px 20px 0;
      gap: 0;
    }

    /* Brand section stays normal */
    #timepads-footer .tp-brand {
      text-align: center;
      padding-bottom: 28px;
      border-bottom: 1px solid var(--tp-border);
    }
    #timepads-footer .tp-brand h2 { font-size: 24px; }
    #timepads-footer .tp-brand p { max-width: 100%; margin-left: auto; margin-right: auto; }

    #timepads-footer .tp-btn-whatsapp {
      width: 100%;
      justify-content: center;
    }
    #timepads-footer .tp-btn-period {
      width: 100%;
    }
    #timepads-footer .tp-socials {
      justify-content: center;
    }

    /* Accordion nav columns */
    #timepads-footer .tp-nav-col {
      border-bottom: 1px solid var(--tp-border);
    }

    #timepads-footer .tp-nav-col h3 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 0;
      padding: 18px 0;
      cursor: pointer;
      user-select: none;
    }

    #timepads-footer .tp-nav-col h3 .tp-chevron {
      width: 18px;
      height: 18px;
      color: var(--tp-orange);
      transition: transform 0.25s;
      flex-shrink: 0;
    }

    #timepads-footer .tp-nav-col.is-open h3 .tp-chevron {
      transform: rotate(180deg);
    }

    #timepads-footer .tp-nav-col ul,
    #timepads-footer .tp-contact-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, padding 0.3s ease;
    }

    #timepads-footer .tp-nav-col.is-open ul,
    #timepads-footer .tp-nav-col.is-open .tp-contact-body {
      max-height: 400px;
      padding-bottom: 20px;
    }

    /* Contact column special styling on mobile */
    #timepads-footer .tp-contact-socials {
      display: none; /* socials already shown in brand on mobile */
    }

    /* Partners */
    #timepads-footer .tp-partners {
      padding: 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    #timepads-footer .tp-partners-label {
      border-right: none;
      padding-right: 0;
      margin-right: 0;
    }
    #timepads-footer .tp-partners-list {
      gap: 8px;
    }
    #timepads-footer .tp-partner-chip {
      font-size: 12px;
      padding: 5px 12px;
    }

    /* Bottom bar */
    #timepads-footer .tp-bottom-bar {
      padding: 18px 20px;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 10px;
    }
    #timepads-footer .tp-bottom-links {
      gap: 16px;
    }
  }
@media only screen and (min-width: 769px){
svg.tp-chevron{
 display: none;
}

}

</style>

