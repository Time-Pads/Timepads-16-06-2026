<script>
(function () {
  function initFooterAccordions() {
    var cols = document.querySelectorAll('#timepads-footer [data-accordion]');
    cols.forEach(function (col) {
      var heading = col.querySelector('h3');
      if (!heading || heading.hasAttribute('data-accordion-bound')) return;
      heading.setAttribute('data-accordion-bound', 'true');
      heading.addEventListener('click', function () {
        if (window.innerWidth > 768) return;
        col.classList.toggle('is-open');
      });
    });
  }

  function scheduleFooterInit() {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(initFooterAccordions, { timeout: 1500 });
      return;
    }
    window.setTimeout(initFooterAccordions, 0);
  }

  if (document.readyState === 'complete') {
    scheduleFooterInit();
  } else {
    window.addEventListener('load', scheduleFooterInit, { once: true });
  }
}());
</script>

