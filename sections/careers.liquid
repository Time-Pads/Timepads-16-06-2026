<!-- THREE.JS -->
<script>
/* ═══════════════════════
   JOB FILTER
═══════════════════════ */
function filterJobs(dept, btn) {
  document.querySelectorAll('.f-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  let v = 0;
  document.querySelectorAll('.job-card').forEach(c => {
    const show = dept === 'all' || c.dataset.dept === dept;
    c.classList.toggle('hidden', !show);
    if (show) v++;
  });
  document.getElementById('no-jobs').style.display = v === 0 ? 'block' : 'none';
}

/* ═══════════════════════
   TOAST
═══════════════════════ */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._tid);
  t._tid = setTimeout(() => t.classList.remove('show'), 3000);
}

/* ═══════════════════════
   IMAGE MANAGER STATE
═══════════════════════ */
let imageStore = [];
let cfg = { size: 130, opacity: 88, speed: 5, layout: 'scatter', floatH: 18, radius: '16px' };

/* Panel open/close */
function openPanel() { document.getElementById('imgOverlay').classList.add('open'); }
function closePanel() { document.getElementById('imgOverlay').classList.remove('open'); }
function handleOverlayClick(e) { if (e.target.id === 'imgOverlay') closePanel(); }

/* Drag & drop */
const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
zone.addEventListener('drop', e => { e.preventDefault(); zone.classList.remove('drag-over'); handleFiles(e.dataTransfer.files); });

/* File reading */
function handleFiles(files) {
  let loaded = 0;
  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;
    const reader = new FileReader();
    reader.onload = ev => {
      const id = 'img_' + Date.now() + '_' + Math.random().toString(36).slice(2, 7);
      const name = file.name.replace(/\.[^.]+$/, '');
      imageStore.push({ id, name, dataUrl: ev.target.result, active: true });
      loaded++;
      if (loaded === Array.from(files).filter(f => f.type.startsWith('image/')).length) {
        renderGrid();
        showToast('✓ ' + loaded + ' image' + (loaded > 1 ? 's' : '') + ' uploaded');
      }
    };
    reader.readAsDataURL(file);
  });
}

/* Render the image grid inside the panel */
function renderGrid() {
  const grid  = document.getElementById('imgGrid');
  const empty = document.getElementById('imgGridEmpty');
  const count = document.getElementById('imgCount');
  const active = imageStore.filter(i => i.active).length;
  count.textContent = '(' + imageStore.length + ' total, ' + active + ' visible — click to toggle)';

  if (imageStore.length === 0) {
    empty.style.display = 'block';
    grid.innerHTML = '';
    return;
  }
  empty.style.display = 'none';
  grid.innerHTML = imageStore.map(img => `
    <div class="img-item ${img.active ? 'active' : ''}" onclick="toggleImg('${img.id}')" title="Click to toggle visibility">
      <img src="${img.dataUrl}" alt="${img.name}" style="background:repeating-conic-gradient(#eee 0% 25%,#fff 0% 50%) 0 0/16px 16px">
      <span class="img-active-badge">ON</span>
      <div class="img-item-label">${img.name.length > 14 ? img.name.slice(0, 12) + '…' : img.name}</div>
      <button class="img-item-del" onclick="deleteImg(event,'${img.id}')" title="Delete">✕</button>
    </div>
  `).join('');
}

function toggleImg(id) {
  const item = imageStore.find(i => i.id === id);
  if (item) { item.active = !item.active; renderGrid(); }
}
function deleteImg(e, id) {
  e.stopPropagation();
  imageStore = imageStore.filter(i => i.id !== id);
  renderGrid();
  refreshSprites();
  showToast('Image removed');
}
function clearAllImages() {
  imageStore = [];
  renderGrid();
  refreshSprites();
  showToast('All images cleared from banner');
}

/* Read settings from controls */
function readSettings() {
  cfg.size    = parseInt(document.getElementById('imgSize').value);
  cfg.opacity = parseInt(document.getElementById('imgOpacity').value);
  cfg.speed   = parseFloat(document.getElementById('floatSpeed').value);
  cfg.layout  = document.getElementById('layoutMode').value;
  cfg.floatH  = parseInt(document.getElementById('floatHeight').value);
  cfg.radius  = document.getElementById('borderRadius').value;
  document.getElementById('imgSizeVal').textContent      = cfg.size + 'px';
  document.getElementById('imgOpacityVal').textContent   = cfg.opacity + '%';
  document.getElementById('floatHeightVal').textContent  = cfg.floatH + 'px';
}

/* Live preview while sliding */
function liveUpdate() { readSettings(); refreshSprites(); }

/* Compute positions for each layout */
function getPositions(count, layout, hero) {
  const W = hero.offsetWidth, H = hero.offsetHeight;
  const s = cfg.size;
  const positions = [];

  const scatter = [
    { lp:.05, tp:.08, rot:-9 },  { lp:.78, tp:.05, rot:11 },
    { lp:.84, tp:.60, rot:-7 },  { lp:.03, tp:.58, rot:8  },
    { lp:.62, tp:.80, rot:-11},  { lp:.16, tp:.76, rot:6  },
    { lp:.48, tp:.04, rot:4  },  { lp:.40, tp:.83, rot:-6 },
    { lp:.88, tp:.32, rot:13 },  { lp:.00, tp:.34, rot:-5 },
    { lp:.26, tp:.03, rot:9  },  { lp:.70, tp:.40, rot:-10},
    { lp:.55, tp:.15, rot:5  },  { lp:.12, tp:.45, rot:-8 },
    { lp:.72, tp:.20, rot:7  },  { lp:.32, tp:.68, rot:-4 },
  ];

  if (layout === 'ring') {
    for (let i = 0; i < count; i++) {
      const a = (i / count) * Math.PI * 2 - Math.PI / 2;
      const rx = W * 0.38, ry = H * 0.35;
      positions.push({ left: W/2 + Math.cos(a)*rx - s/2, top: H/2 + Math.sin(a)*ry - s/2, rot: (a*180/Math.PI)*0.08, delay: i*0.55 });
    }
  } else if (layout === 'sides') {
    const half = Math.ceil(count / 2);
    for (let i = 0; i < count; i++) {
      const side = i < half ? 0 : 1;
      const idx  = side === 0 ? i : i - half;
      const cols = side === 0 ? half : count - half;
      const spacing = cols > 1 ? (H * 0.7) / (cols - 1) : 0;
      positions.push({
        left:  side === 0 ? W * 0.03 : W * 0.83 - s,
        top:   H * 0.12 + idx * spacing,
        rot:   (Math.random() - 0.5) * 14,
        delay: i * 0.45
      });
    }
  } else if (layout === 'corners') {
    const corners = [
      { lp:.02, tp:.04 }, { lp:.80, tp:.04 },
      { lp:.02, tp:.72 }, { lp:.80, tp:.72 },
      { lp:.40, tp:.03 }, { lp:.40, tp:.74 },
      { lp:.02, tp:.38 }, { lp:.82, tp:.38 },
    ];
    for (let i = 0; i < count; i++) {
      const c = corners[i % corners.length];
      positions.push({ left: c.lp*W, top: c.tp*H, rot:(Math.random()-0.5)*16, delay: i*0.5 });
    }
  } else {
    for (let i = 0; i < count; i++) {
      const p = scatter[i % scatter.length];
      positions.push({ left: p.lp*W, top: p.tp*H, rot: p.rot, delay: i*0.6 });
    }
  }
  return positions;
}

/* Remove & re-inject all sprites */
function refreshSprites() {
  const hero = document.getElementById('hero');
  hero.querySelectorAll('.hero-img-sprite').forEach(el => el.remove());
  const active = imageStore.filter(i => i.active);
  if (!active.length) return;

  const positions = getPositions(active.length, cfg.layout, hero);
  active.forEach((img, idx) => {
    const pos = positions[idx];
    const el  = document.createElement('img');
    el.src       = img.dataUrl;
    el.alt       = img.name;
    el.className = 'hero-img-sprite';
    const maxL   = Math.max(0, Math.min(pos.left, hero.offsetWidth  - cfg.size));
    const maxT   = Math.max(0, Math.min(pos.top,  hero.offsetHeight - cfg.size));
    el.style.cssText = [
      `width:${cfg.size}px`, `height:${cfg.size}px`,
      `opacity:${cfg.opacity/100}`,
      `left:${maxL}px`, `top:${maxT}px`,
      `--rot:${pos.rot}deg`,
      `animation-duration:${cfg.speed}s`,
      `animation-delay:${pos.delay}s`,
      `border-radius:${cfg.radius}`,
      `--float-h:${cfg.floatH}px`,
    ].join(';');
    hero.appendChild(el);
  });
}

function applyImages() {
  readSettings();
  refreshSprites();
  closePanel();
  const n = imageStore.filter(i => i.active).length;
  showToast(n > 0 ? `✓ Banner updated — ${n} product image${n>1?'s':''} now floating!` : '✓ Banner cleared');
}

/* Override float-height CSS var per element */
document.head.insertAdjacentHTML('beforeend', `<style>
  @keyframes sprite-float {
    0%   { transform: translateY(0px) rotate(var(--rot,0deg)) scale(1); }
    100% { transform: translateY(calc(var(--float-h, 18px) * -1)) rotate(var(--rot,0deg)) scale(1.03); }
  }
</style>`);

/* ═══════════════════════
   THREE.JS — 3D PRODUCTS
═══════════════════════ */

</script>
