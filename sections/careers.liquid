{% schema %}
{
  "name": "careers",
  "settings": [
   ],
  "presets": [
    {
      "name": "careers"
    }
  ]
}
{% endschema %}

<style>
    .main-content>.shopify-section:only-child{
    background: white;
    }
  :root{
    --cream:#F5EFE6;--cream-d:#EDE4D6;--cream-b:#D4C4B0;
    --gold:#C8A96E;--gold-d:#A8894E;--gold-l:#E2CFA4;
    --coral:#E8847A;--white:#FFFFFF;
    --dark:#1A1612;--dark2:#2C2420;
    --text-d:#2C2C2C;--text-b:#5C5040;--text-m:#8C7A68;--card:#FAF6F1;
  }
  body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-d);overflow-x:hidden}

  /* NAV */
  .nav{
    background:linear-gradient(180deg,rgba(245,239,230,0.98),rgba(245,239,230,0.92));
    backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-bottom:1px solid rgba(212,196,176,0.6);
    padding:.9rem 3rem;display:flex;align-items:center;justify-content:space-between;
    position:sticky;top:0;z-index:200;
    box-shadow:0 2px 40px rgba(168,137,78,.08),0 1px 0 rgba(255,255,255,.7) inset;
  }
  .nav-logo{font-family:var(--TYPE-STACK-NAV);font-size:1.5rem;font-weight:600;color:var(--text-d);text-decoration:none;letter-spacing:.06em}
  .nav-right{display:flex;align-items:center;gap:12px}
  .nav-badge{font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;background:linear-gradient(135deg,var(--gold),var(--gold-d));color:#fff;padding:5px 16px;border-radius:20px;box-shadow:0 4px 12px rgba(168,137,78,.4),0 1px 0 rgba(255,255,255,.3) inset}
  .nav-edit-btn{font-size:12px;font-weight:500;color:var(--gold-d);background:linear-gradient(145deg,#fff,var(--card));border:1.5px solid var(--cream-b);border-radius:20px;padding:5px 14px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;box-shadow:0 2px 8px rgba(168,137,78,.08)}
  .nav-edit-btn:hover{border-color:var(--gold);background:var(--cream)}

  /* HERO */
  #c3d{position:absolute;inset:0;width:100%;height:100%;display:block;z-index:0}
  .orb{position:absolute;border-radius:50%;pointer-events:none}
  .orb1{width:500px;height:500px;top:-180px;right:-120px;background:radial-gradient(circle at 35% 35%,rgba(200,169,110,.14),transparent 60%);animation:od 18s ease-in-out infinite alternate}
  .orb2{width:300px;height:300px;bottom:-100px;left:-80px;background:radial-gradient(circle at 40% 40%,rgba(232,132,122,.1),transparent 65%);animation:od 14s 3s ease-in-out infinite alternate-reverse}
  @keyframes od{0%{transform:translate(0,0)}100%{transform:translate(25px,18px)}}

  /* Floating image sprites */
  .hero-img-sprite{
    position:absolute;z-index:1;pointer-events:none;border-radius:12px;object-fit:contain;
    filter:drop-shadow(0 8px 24px rgba(0,0,0,.5));
    animation:sprite-float 6s ease-in-out infinite alternate;
  }
  @keyframes sprite-float{
    0%{transform:translateY(0px) rotate(var(--rot,0deg)) scale(1)}
    100%{transform:translateY(-18px) rotate(var(--rot,0deg)) scale(1.03)}
  }

  .hero-content{position:relative;z-index:2;text-align:center;padding:2rem}
  .hero-pill{display:inline-block;margin-bottom:1.8rem;font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;background:linear-gradient(135deg,rgba(200,169,110,.25),rgba(200,169,110,.1));color:var(--gold-l);border:1px solid rgba(200,169,110,.35);padding:7px 22px;border-radius:24px;animation:fu .9s ease both}
  .hero h1{font-family:var(--TYPE-STACK-NAV);font-size:clamp(2.6rem,6vw,4.8rem);font-weight:600;color:#fff;line-height:1.15;margin-bottom:1.2rem;text-shadow:0 4px 40px rgba(0,0,0,.6);animation:fu .9s .15s ease both}
  .hero h1 em{font-style:italic;background:linear-gradient(135deg,var(--gold-l),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero p{color:rgba(255,255,255,.62);font-size:16px;font-weight:300;line-height:1.8;max-width:480px;margin:0 auto 3rem;animation:fu .9s .3s ease both}
  .hero-stats{display:flex;justify-content:center;gap:3.5rem;flex-wrap:wrap;animation:fu .9s .45s ease both}
  .hero-stat strong{display:block;font-family:var(--TYPE-STACK-NAV);font-size:2.5rem;font-weight:600;line-height:1;background:linear-gradient(135deg,#fff,var(--gold-l));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero-stat span{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.42);margin-top:6px;display:block}
  @keyframes fu{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}

  /* IMAGE MANAGER PANEL */
  .img-panel-overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(26,22,18,0.72);backdrop-filter:blur(6px);align-items:center;justify-content:center}
  .img-panel-overlay.open{display:flex}
  .img-panel{background:linear-gradient(145deg,#fff,var(--card));border-radius:24px;padding:2.2rem;width:min(700px,95vw);max-height:90vh;overflow-y:auto;box-shadow:0 40px 100px rgba(0,0,0,.4),0 1px 0 rgba(255,255,255,.8) inset;border:1px solid rgba(212,196,176,.8)}
  .img-panel-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.6rem}
  .img-panel-head h2{font-family:var(--TYPE-STACK-NAV);font-size:1.4rem;font-weight:600;color:var(--text-d)}
  .img-panel-close{width:36px;height:36px;border-radius:50%;border:1.5px solid var(--cream-b);background:var(--cream);color:var(--text-m);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .18s}
  .img-panel-close:hover{background:var(--coral);color:#fff;border-color:var(--coral)}

  .img-upload-zone{border:2px dashed var(--cream-b);border-radius:16px;padding:2rem;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:1.6rem;background:linear-gradient(135deg,var(--cream),rgba(245,239,230,.5));position:relative}
  .img-upload-zone:hover{border-color:var(--gold);background:rgba(200,169,110,.06)}
  .img-upload-zone.drag-over{border-color:var(--gold);background:rgba(200,169,110,.12);transform:scale(1.01)}
  .img-upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
  .upload-icon{font-size:2.5rem;margin-bottom:.7rem;display:block}
  .upload-label{font-size:14px;font-weight:500;color:var(--text-d);display:block;margin-bottom:.3rem}
  .upload-sub{font-size:12px;color:var(--text-m)}

  .panel-section-label{font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:var(--gold-d);font-weight:500;margin-bottom:.8rem}
  .img-empty{text-align:center;padding:1.5rem;color:var(--text-m);font-size:13px;background:var(--cream);border-radius:12px;border:1px dashed var(--cream-b)}

  .img-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:12px;margin-bottom:1.4rem}
  .img-item{position:relative;border-radius:12px;overflow:hidden;border:2.5px solid var(--cream-b);background:var(--cream);aspect-ratio:1;transition:border-color .18s,transform .18s;cursor:pointer}
  .img-item:hover{border-color:var(--gold-l);transform:translateY(-2px)}
  .img-item.active{border-color:var(--gold);box-shadow:0 0 0 3px rgba(200,169,110,.25)}
  .img-item img{width:100%;height:100%;object-fit:cover;display:block}
  .img-active-badge{position:absolute;top:6px;left:6px;background:var(--gold);color:#fff;font-size:9px;font-weight:600;letter-spacing:.06em;padding:2px 7px;border-radius:8px;text-transform:uppercase;opacity:0;transition:opacity .18s}
  .img-item.active .img-active-badge{opacity:1}
  .img-item-label{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(26,22,18,.75));color:#fff;font-size:10px;padding:6px 8px 5px;font-weight:500}
  .img-item-del{position:absolute;top:5px;right:5px;width:22px;height:22px;border-radius:50%;background:rgba(232,132,122,.9);color:#fff;border:none;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .18s}
  .img-item:hover .img-item-del{opacity:1}

  .img-settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:1.8rem;padding:1.2rem;background:var(--cream);border-radius:14px;border:1px solid var(--cream-b)}
  .img-setting label{font-size:12px;color:var(--text-m);display:block;margin-bottom:5px;font-weight:500}
  .img-setting input[type=range]{width:100%;accent-color:var(--gold);margin-bottom:2px}
  .val-readout{font-size:12px;color:var(--gold-d);font-weight:500}
  .img-setting select{width:100%;padding:7px 10px;border-radius:8px;border:1.5px solid var(--cream-b);font-family:'DM Sans',sans-serif;font-size:13px;background:#fff;color:var(--text-d);outline:none;transition:border-color .18s;cursor:pointer}
  .img-setting select:focus{border-color:var(--gold)}

  .panel-actions{display:flex;gap:10px;justify-content:flex-end;border-top:1px solid var(--cream-b);padding-top:1.2rem;margin-top:.4rem}
  .btn-sec{padding:9px 20px;border-radius:20px;font-size:13px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;border:1.5px solid var(--cream-b);background:var(--cream);color:var(--text-b);transition:all .18s}
  .btn-sec:hover{border-color:var(--gold);color:var(--gold-d)}
  .btn-pri{padding:9px 24px;border-radius:20px;font-size:13px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;border:none;background:linear-gradient(135deg,var(--gold),var(--gold-d));color:#fff;box-shadow:0 6px 16px rgba(168,137,78,.4);transition:all .2s}
  .btn-pri:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(168,137,78,.5)}

  /* LAYOUT SECTIONS */
  .outer{max-width:1440px; margin:0 auto}
  .sec{padding:5rem 2.5rem}
  .sec-alt{background:linear-gradient(180deg,var(--cream-d),var(--cream));border-top:1px solid rgba(212,196,176,.7);border-bottom:1px solid rgba(212,196,176,.7)}
  .sec-head{text-align:center;margin-bottom:3rem}
  .sec-label{font-size:14px;text-transform:uppercase;letter-spacing:0em;color:var(--gold-d);font-weight:900;margin-bottom:.4rem}
  .sec-title{font-family:var(--TYPE-STACK-NAV); font-size:clamp(1.8rem,3vw,2.6rem);font-weight:600;color:var(--text-d);margin-bottom:.5rem}
  .sec-sub{color:black;font-size:14px;font-weight:900;margin-top:.6rem}
  .divider{width:48px;height:2px;background:linear-gradient(90deg,var(--gold),var(--gold-l));margin:.8rem auto 0;border-radius:2px;box-shadow:0 2px 8px rgba(200,169,110,.4)}

  /* VALUE CARDS */
  .vals-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:16px}
  .val-card{background:linear-gradient(145deg,#fff,var(--card));border:1px solid rgba(212,196,176,.7);border-radius:20px;padding:2rem 1.5rem;text-align:center;cursor:default;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s,border-color .3s;box-shadow:0 2px 0 rgba(255,255,255,.9) inset,0 8px 24px rgba(168,137,78,.06);transform-style:preserve-3d}
  .val-card:hover{transform:translateY(-8px) rotateX(4deg) rotateY(-2deg);box-shadow:0 2px 0 rgba(255,255,255,.9) inset,0 24px 48px rgba(168,137,78,.18);border-color:var(--gold)}
  .val-icon{width:60px;height:60px;border-radius:50%;margin:0 auto 1.1rem;display:flex;align-items:center;justify-content:center;font-size:24px;background:linear-gradient(145deg,var(--cream),var(--cream-d));border:1px solid rgba(212,196,176,.8);box-shadow:0 4px 12px rgba(168,137,78,.12),0 1px 0 rgba(255,255,255,.8) inset}
  .val-card h3{font-size:14px;font-weight:500;color:var(--text-d);margin-bottom:.45rem}
  .val-card p{font-size:13px;color:var(--text-m);line-height:1.6;font-weight:300}

  /* FILTER & JOBS */
  .filter-row{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:2.2rem}
  .f-btn{background:linear-gradient(145deg,#fff,var(--card));border:1.5px solid var(--cream-b);color:var(--text-m);border-radius:24px;padding:7px 20px;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .22s cubic-bezier(.34,1.56,.64,1);box-shadow:0 2px 6px rgba(168,137,78,.06)}
  .f-btn:hover{border-color:var(--gold);color:var(--gold-d);transform:translateY(-2px)}
  .f-btn.active{background:linear-gradient(135deg,var(--gold),var(--gold-d));border-color:var(--gold-d);color:#fff;font-weight:500;box-shadow:0 6px 20px rgba(168,137,78,.45);transform:translateY(-2px)}
  .jobs-list{display:flex;flex-direction:column;gap:14px}
  .job-card{background:linear-gradient(145deg,#fff,var(--card));border:1.5px solid rgba(212,196,176,.8);border-radius:18px;padding:1.4rem 1.8rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s,border-color .25s;box-shadow:0 2px 0 rgba(255,255,255,.95) inset,0 4px 16px rgba(168,137,78,.05);position:relative;overflow:hidden}
  .job-card::before{border-radius:17px;opacity:0;transition:opacity .25s;background:linear-gradient(135deg,rgba(200,169,110,.05),transparent 60%)}
  .job-card:hover{transform:translateX(6px) translateY(-3px);border-color:var(--gold);box-shadow:0 2px 0 rgba(255,255,255,.95) inset,-6px 16px 40px rgba(168,137,78,.2)}
  .job-card:hover::before{opacity:1}
  .job-card.hidden{display:none}
  .job-title{font-size:15px;font-weight:500;color:var(--text-d);margin-bottom:.55rem}
  .tags{display:flex;flex-wrap:wrap;gap:7px;align-items:center}
  .tag{font-size:11px;font-weight:500;border-radius:10px;padding:3px 11px;text-transform:uppercase;letter-spacing:.04em}
  .t-dept{background:linear-gradient(135deg,var(--cream),var(--cream-d));color:var(--gold-d);border:1px solid rgba(212,196,176,.8)}
  .t-type{background:#F0EBE3;color:var(--text-b)}
  .t-loc{background:linear-gradient(135deg,#EBF3EC,#D6ECD8);color:#1B5E20}
  .t-new{background:linear-gradient(135deg,var(--coral),#D4605A);color:#fff;box-shadow:0 2px 8px rgba(232,132,122,.4)}
  .apply-btn{background:linear-gradient(135deg,var(--gold),var(--gold-d));color:#fff;border:none;border-radius:24px;padding:11px 24px;font-size:13px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .22s cubic-bezier(.34,1.56,.64,1);box-shadow:0 6px 18px rgba(168,137,78,.4),0 1px 0 rgba(255,255,255,.25) inset}
  .apply-btn:hover{transform:translateY(-3px) scale(1.04);box-shadow:0 10px 28px rgba(168,137,78,.55)}
  .apply-btn:active{transform:scale(.97)}
  .no-jobs{text-align:center;padding:2.5rem;color:var(--text-m);font-size:14px;background:var(--cream);border-radius:14px;border:1.5px dashed var(--cream-b);display:none}

  /* PROCESS */
  .steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:10px;margin-top:2.5rem;text-align:center}
  .step{padding:1.5rem .75rem;position:relative;transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
  .step:hover{transform:translateY(-6px)}
  .step:not(:last-child)::after{content:'→';position:absolute;right:-12px;top:2.1rem;color:var(--gold-l);font-size:20px;opacity:.7}
  .step-num{width:50px;height:50px;border-radius:50%;background:linear-gradient(145deg,var(--gold),var(--gold-d));color:#fff;font-size:15px;font-weight:500;display:flex;align-items:center;justify-content:center;margin:0 auto .9rem;box-shadow:0 8px 20px rgba(168,137,78,.45),0 1px 0 rgba(255,255,255,.3) inset;transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
  .step:hover .step-num{transform:scale(1.15) rotateY(20deg)}
  .step h4{font-size:13px;font-weight:500;color:var(--text-d);margin-bottom:4px}
  .step p{font-size:12px;color:var(--text-m);font-weight:300;line-height:1.4}

  /* PERKS */
  .perks-grid{display:flex; flex-wrap: wrap; justify-content: center; grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
  .perk{display:flex; flex: 0 0 30%; align-items:flex-start;gap:14px;background:linear-gradient(145deg,#fff,var(--card));border:1px solid rgba(212,196,176,.7);border-radius:16px;padding:1.2rem 1.3rem;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s,border-color .3s;box-shadow:0 2px 0 rgba(255,255,255,.9) inset}
  .perk:hover{transform:translateY(-5px) rotateX(3deg);border-color:var(--gold);box-shadow:0 2px 0 rgba(255,255,255,.9) inset,0 16px 36px rgba(168,137,78,.18)}
  .perk-icon{width:46px;height:46px;border-radius:12px;flex-shrink:0;background:linear-gradient(145deg,var(--cream),var(--cream-d));border:1px solid rgba(212,196,176,.9);display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 10px rgba(168,137,78,.1)}
  .perk h4{font-size:13px;font-weight:500;color:var(--text-d);margin-bottom:3px}
  .perk p{font-size:12px;color:var(--text-m);font-weight:300;line-height:1.45}

  
.right-role img{
position: absolute;
z-index: 9999;
    top: -9rem;
    width: 50%;
}
.sec.why-join-us{
  margin-bottom: 8rem;
}
.right-role  h2{
z-index: 999999 !important;
}
@media only screen and (max-width: 769px){
.perk{
 flex: 0 0 100%;
}
.right-role img{

top: -9.9rem;
width: 100% !important;
}

}


.right-role{
position: relative;
}



  /* CTA */
  .cta-wrap{padding:0 2.5rem 5rem}
  .cta{background:linear-gradient(145deg,var(--dark),var(--dark2),#1E160C);border-radius:24px;padding:4rem 2.5rem;text-align:center;color:#fff;position:relative;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.35),0 1px 0 rgba(255,255,255,.05) inset}
  .cta-orb{position:absolute;border-radius:50%;pointer-events:none}
  .cta-orb1{width:400px;height:400px;top:-150px;right:-80px;background:radial-gradient(circle at 40% 40%,rgba(200,169,110,.18),transparent 65%)}
  .cta-orb2{width:250px;height:250px;bottom:-100px;left:-50px;background:radial-gradient(circle at 50% 50%,rgba(200,169,110,.1),transparent 65%)}
  .cta-shine{position:absolute;top:0;left:-60%;width:40%;height:100%;background:linear-gradient(105deg,transparent,rgba(255,255,255,.04),transparent);animation:shine 8s 2s ease-in-out infinite}
  @keyframes shine{0%,100%{left:-60%}50%{left:120%}}
  .cta h2{font-family:var(--TYPE-STACK-NAV); font-size:clamp(1.7rem,3vw,2.3rem);font-weight:600;margin-bottom:.8rem;position:relative;z-index:1}
  .cta h2 em{font-style:italic;background:linear-gradient(135deg,var(--gold-l),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .cta p{font-size:15px;opacity:.72;font-weight:300;margin-bottom:2.2rem;max-width:460px;margin-left:auto;margin-right:auto;line-height:1.7;position:relative;z-index:9999999}
  .cta a{display:inline-block;background:linear-gradient(135deg,var(--gold),var(--gold-d));color:#fff;font-size:14px;font-weight:500;border-radius:30px;padding:14px 34px;text-decoration:none;font-family:'DM Sans',sans-serif;box-shadow:0 8px 24px rgba(168,137,78,.55);transition:all .25s cubic-bezier(.34,1.56,.64,1);position:relative;z-index:1}
  .cta a:hover{transform:translateY(-4px) scale(1.04);box-shadow:0 14px 36px rgba(168,137,78,.7)}

  /* FOOTER */


  /* TOAST */
  .toast{position:fixed;bottom:2rem;right:2rem;z-index:9999;background:var(--dark);color:#fff;font-size:13px;padding:12px 20px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.4);opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none;max-width:300px}
  .toast.show{opacity:1;transform:none}

  @media(max-width:600px){
    .nav{padding:.8rem 1.2rem}
    .sec{padding:3.5rem 1.2rem}
    .hero-stats{gap:2rem}
    .step:not(:last-child)::after{display:none}
    .cta-wrap{padding:0 1.2rem 3.5rem}
    .img-settings-grid{grid-template-columns:1fr}
    .nav-edit-btn span.label{display:none}
  }
</style>



<!-- HERO -->
<section class="hero" id="hero">
  <picture class="hero-bg">
    <source media="(max-width: 768px)" srcset="{{ 'Sanitary-Pads-Banner-Mobile_1.jpg' | file_url | image_url: width: 800 }}">
    <img src="{{ 'Sanitary-Pads-Banner-Desktop_2.jpg' | file_url | image_url: width: 1200 }}" alt="Hero Banner">
  </picture>

</section>

<!-- VALUES -->
<div class="sec-alt"><div class="outer"><div class="sec">
  <div class="sec-head">
    <div class="sec-label">Who we are</div>
    <h2 class="sec-title">Our core values</h2>
    <div class="divider"></div>
    <p class="sec-sub">The principles behind every product — and every hire</p>
