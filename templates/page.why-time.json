    "section_richtext_xMxmjw": {
      "type": "section-richtext",
      "blocks": {
        "kicker_cMFFkb": {
          "type": "kicker",
          "settings": {
            "kicker": "Know Our Products:",
            "enable_line": true,
            "text_size": 8
          }
        },
        "heading_MUgrfR": {
