    "image_columns_with_text_reLjTW": {
      "type": "image-columns-with-text",
      "blocks": {
        "text_block_BidJgh": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Slide-1_2.jpg",
            "alt_text": "period pads",
            "shape_class": "",
            "title": "",
            "text": "<h3><strong>Designed for Women’s Comfort</strong></h3><p>We believe in saying<strong>'Bye Women' to discomfort and outdated solutions, and 'Hi Women' to confidence, care, and innovation</strong>. Our <strong>sanitary pads </strong>are designed with advanced technology to provide superior absorbency, skin-friendly materials, and ultimate comfort, empowering women to embrace their day with ease and assurance.\"</p>",
            "button_label": "",
            "button_link": "",
            "button_color": "btn--neutral",
            "button_style": "btn--soft",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
            "video_button_color": "text--white"
          }
        },
        "text_block_d3KNtU": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Slide-2_7.jpg",
            "alt_text": "sanitary pads",
            "shape_class": "",
            "title": "",
            "text": "<h3><strong>Advanced Hot Air Pressed Technology</strong></h3><p>This process binds layers tightly, eliminating the need for adhesives that could irritate the skin. It also enhances the durability and absorbency of the <strong>pad</strong>, ensuring reliable performance.</p>",
            "button_label": "",
            "button_link": "",
            "button_color": "btn--neutral",
            "button_style": "btn--soft",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
            "video_button_color": "text--white"
          }
        },
        "text_block_tyCn8K": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Slide-3_7.jpg",
            "alt_text": "long night time sanitary pads",
            "shape_class": "",
            "title": "",
            "text": "<h3><strong>High-Quality Sanitary Pads</strong></h3><p>Sanitary pads are designed with high absorbency to manage menstrual flow effectively and prevent leaks.<strong>Eco-friendly sanitary pads</strong> with multiple durable layers offer long-lasting protection. Advanced quality checks ensure the<strong>best pads for heavy flow</strong> meet safety and performance standards.</p>",
            "button_label": "",
            "button_link": "",
            "button_color": "btn--neutral",
            "button_style": "btn--soft",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
            "video_button_color": "text--white"
          }
        },
        "text_block_ECCWgh": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Slide-4_6.jpg",
            "alt_text": "cotton absorbent sanitary pads",
            "shape_class": "",
            "title": "",
            "text": "<h3><strong>Safe & Gentle on Skin</strong></h3><p>Made with soft, hypoallergenic materials,<strong>TIME pads </strong>are gentle on sensitive skin to prevent rashes or irritation. Dermatologically tested and free from harmful chemicals like chlorine or artificial fragrances. This ensures a comfortable experience throughout the day.</p>",
            "button_label": "",
            "button_link": "",
            "button_color": "btn--neutral",
            "button_style": "btn--soft",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
            "video_button_color": "text--white"
          }
        }
      },
