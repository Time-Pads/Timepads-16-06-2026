      "blocks": {
        "faq_QMfUdQ": {
          "type": "faq",
          "settings": {
            "question": "1. Why should I switch to the TIME Menstrual Cup?",
            "answer": "TIME Menstrual Cup saves money, prevents rashes, and is eco-friendly. One cup lasts 5\nyears, It’s comfortable for work, travel, and sleep."
          }
        },
        "faq_pQiNBt": {
          "type": "faq",
          "settings": {
            "question": "2. Is TIME Menstrual Cup safe for sensitive skin?",
            "answer": "Yes 👍 It is made from 100% medical-grade silicone, BPA-free, toxin-free, and dermatologically safe. No smell, no itching, no rashes."
          }
        },
        "faq_DkLWcq": {
          "type": "faq",
          "settings": {
            "question": "3. Can I use it during heavy flow or overnight?",
            "answer": "Yes. TIME Menstrual cups hold 3× more fluid than pads and can be worn safely for 6–8 hours, even overnight. Just empty earlier on very heavy days."
          }
        },
        "faq_NWCQgK": {
          "type": "faq",
          "settings": {
            "question": "4. How do I clean and maintain the cup?",
            "answer": "During periods → Wash with clean water or mild soap\nAfter periods → Boil in water for 5 minutes\n\nDry and store in the breathable pouch provided."
          }
        },
        "faq_Y8UPKf": {
          "type": "faq",
          "settings": {
            "question": "5. What if the cup doesn’t fit or I’m not comfortable?",
            "answer": "Don’t worry 😊 Most users need 1–2 cycles to adjust.\nIf you still feel uncomfortable, try a different fold or size."
          }
        },
        "faq_E7EjGz": {
          "type": "faq",
          "settings": {
            "question": "6. What if cup gets stuck?",
            "answer": "Don’t worry 😊 A menstrual cup cannot get lost inside your body.\n\nStay calm and try these steps:\n\nRelax your muscles and take slow breaths.\n\nGently pinch the base of the cup to break the suction seal.\n\nIf needed, slide one finger along the side of the cup and press the rim inward to release the seal.\n\nSlowly wiggle and pull the cup downward.\n\nIf it still feels difficult, squat or sit on the toilet to make removal easier.\n\n👉 Most users need a few cycles to get comfortable."
          }
        }
