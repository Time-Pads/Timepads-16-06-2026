    "menstrual_cup_text_CBLY6A": {
      "type": "menstrual-cup-text",
      "blocks": {
        "info_block_apPAnE": {
          "type": "info_block",
          "settings": {
            "title": "What is a menstrual cup?",
            "text": "A menstrual cup is the most economical menstrual product so far. Our cup is made of 100% Medical-Grade Silicone and is supposed to be inserted into your vagina. It collects menstrual blood and no, it does not leak. On an average, we bleed just about 20 ml a day and you can keep it in for 8-12 hours.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_FRcH4C": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "SMALL (16 ml)",
            "text": "For girls who are under 18 years of age.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_CVnenq": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "MEDIUM (21 ml)",
            "text": "For women who are above 18 years of age and have not given birth, or have given birth via C-section.",
            "layout": "right",
            "divider": false
          }
        },
        "info_block_ErgTBM": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "LARGE (26 ml)",
            "text": "For women who have given birth vaginally.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_igAMJj": {
          "type": "info_block",
          "settings": {
            "title": "Getting started",
            "text": "Our menstrual cups are made in India. The manufacturing facility is germ free and completely sterile ensuring the cup is safe to use. However, After opening, sterilize the cup before use. During one menstrual cycle you can wash the cup, and between 2 cycles sterilize it.\nAlways wash your hands with water and antibacterial soap before inserting or removing the cup.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_xzzDwY": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "When to wash",
            "text": "During your cycle, you can just wash the menstrual cup with water and gentle unscented soap. However, when you are inserting it for the first time at the beginning of your next cycle, you must sterilize the cup.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_zbP8q3": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "How to sterilize",
            "text": "For sterilizing the cup, you can simply put it in a pot of boiling water for 3-5 minutes or use a microwave. Make sure the cup is fully submerged in water. A simple and hassle free method is to use our menstrual cup sterilizer.",
            "layout": "right",
            "divider": false
          }
        },
        "info_block_hbpYg6": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "Do I ever need to replace my cup?",
            "text": "You can easily reuse the cup for five years. Do not be alarmed if your cup looks discoloured over time. Although, if there are any tears, rips or texture change then it's time to replace it.\nBut don't worry, you won't need to think about that for the next few years.",
            "layout": "left",
            "divider": false
          }
        },
        "info_block_rT9Cdc": {
          "type": "info_block",
          "settings": {
            "image": "shopify://shop_images/download_1_401f5db5-c1d0-4b5e-bab6-fee8ca30aad8.jpg",
            "title": "Making yourself comfortable",
            "text": "At no given point should the stem be left outside your vagina. It should sit right inside your vagina.\nOur stem does not need any trimming. It's designed to make the usage and pulling out process simpler and easier.",
            "layout": "right",
            "divider": false
          }
        }
      },
