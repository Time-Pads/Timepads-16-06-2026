<!-- /snippets/comment.liquid -->
{% comment %}
  * This snippet generates the structure of a comment, including comments that were
  * just published but not yet approved.
  {% render 'comment', comment: comment %}
{% endcomment %}

<!-- /snippets/comment.liquid -->
<div class="comment-card">
  <p class="comment-message">{{ comment.content }}</p>

  <div class="comment-footer">
    <span class="comment-author">{{ comment.author }}</span>
    <span class="dot">•</span>
    <span class="comment-date">{{ comment.created_at | date: "%B %d, %Y" }}</span>
  </div>
</div>


{% style %}
 .comment-card {
  background: #fafafa;
  border: 1px solid #eee;
  border-radius: 12px;
  padding: 24px 28px;
  margin: 20px 0;
  text-align: center;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.comment-message {
  font-size: 17px;
  font-weight: 400;
  color: #333;
  line-height: 1.7;
  margin-bottom: 16px;
}

.comment-footer {
  font-size: 14px;
  color: #555;
  display: flex;
  justify-content: center;
  gap: 6px;
  align-items: center;
}

.comment-author {
  font-weight: 600;
  color: #222;
}

.dot {
  color: #999;
}

.comment-date {
  color: #777;
}

{% endstyle %}