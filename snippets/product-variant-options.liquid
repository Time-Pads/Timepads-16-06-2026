          endif
          if settings.variant_form == 'auto' and longest_value < 16
            assign variant_style = 'button'
          endif
        -%}

        <div data-swapper-wrapper data-split-select-wrapper
          class="selector-wrapper js"
          data-select-label="{{ option.name }}"
          data-option-position="{{ option.position }}"
        >

          {%- assign current_value = current_variant.options[forloop.index0] -%}

          <fieldset class="radio__fieldset">
            <legend class="radio__legend  {% if product.handle == 'period-pain-relief-cream' %}  bundle-product-heading {% endif %}" aria-label="{{ option.name | escape_once }}">




              {% comment %} <span class="radio__legend__label">{{ option.name | escape_once }}</span>
 {% endcomment %}

 <span class="radio__legend__label">
  {% if product.handle == 'period-pain-relief-cream' %}
