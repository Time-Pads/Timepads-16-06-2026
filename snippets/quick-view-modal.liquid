{% comment %}
  Quick View Modal
  Renders a global quick-view overlay. Populated dynamically via quick-view.js.
  Include once in theme.liquid just before </body>:
    {% render 'quick-view-modal' %}
{% endcomment %}

<div id="quick-view-overlay" class="qv-overlay" role="dialog" aria-modal="true" aria-label="Quick view" hidden>
  <div class="qv-backdrop"></div>

  <div class="qv-modal">
    <!-- Close -->
    <button class="qv-close" aria-label="Close quick view">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Prev / Next (carousel arrows) -->
    <button class="qv-nav qv-nav--prev" aria-label="Previous product">
      <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 1L1 9L9 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="qv-nav qv-nav--next" aria-label="Next product">
      <svg width="10" height="18" viewBox="0 0 10 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Content area -->
    <div class="qv-inner">
      <!-- Left: Image -->
      <div class="qv-image-wrap">
        <img class="qv-image" src="" alt="" fetchpriority="high" decoding="async">
      </div>

      <!-- Right: Product info -->
      <div class="qv-info">
        <div class="qv-info-content">
          <h2 class="qv-title"></h2>

          <div class="qv-price-row">
            <span class="qv-price"></span>
            <span class="qv-badge" style="display:none;"></span>
          </div>

          <!-- Variants / options -->
          <div class="qv-options"></div>
        </div>

        <div class="qv-sticky-actions">
          <!-- Quantity -->
          <div class="qv-qty-container">
            <div class="qv-option-label">Quantity</div>
            <div class="qv-qty-control">
              <button class="qv-qty-btn qv-qty-minus" aria-label="Decrease quantity">&#8722;</button>
              <input class="qv-qty-input" type="number" name="quantity" value="1" min="1" aria-label="Quantity">
              <button class="qv-qty-btn qv-qty-plus" aria-label="Increase quantity">&#43;</button>
            </div>
          </div>

          <button class="qv-atc-btn" data-variant-id="">ADD TO CART</button>

          <a class="qv-full-link" href="#">
            View full details
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
