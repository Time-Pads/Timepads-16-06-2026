{% comment %}
  product-card-icons.liquid
  
  Renders the hover icon row (cart / eye / wishlist) on product cards.
  Matches the three-icon layout shown in the reference design (image 1).

  Usage inside your product card image wrapper:
    {% render 'product-card-icons',
        product: product,
        variant: variant
    %}

  Parameters:
    product {object} - The product object
    variant {object} - The currently displayed variant (used to pre-select in quick view)
{% endcomment %}

<div class="product-card-icons">

  {%- comment -%} Eye / Quick View icon {%- endcomment -%}
  <button
    class="product-card-icon-btn product-card-icon-btn--qv"
    aria-label="Quick view {{ product.title | escape }}"
    data-qv-trigger
    data-qv-handle="{{ product.handle }}"
    data-qv-variant="{{ variant.id }}"
  >
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"/>
    </svg>
  </button>

  {%- comment -%} Share icon {%- endcomment -%}
  <button
    class="product-card-icon-btn product-card-icon-btn--share"
    aria-label="Share {{ product.title | escape }}"
    data-share-trigger
    data-share-title="{{ product.title | escape }}"
    data-share-url="{{ shop.url }}{{ product.url }}"
  >
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="18" cy="5" r="3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="18" cy="19" r="3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

</div>
