{%- if template.name == 'index' -%}
    {% assign preload_image_desktop = settings.preload_image_desktop %}
    {% assign preload_image_mobile = settings.preload_image_mobile %}
  
    {% if preload_image_desktop != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(min-width: 768px)"
        href="{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_desktop.width >= 375 -%}{{ preload_image_desktop | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_desktop.width >= 550 -%}{{ preload_image_desktop | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_desktop.width >= 750 -%}{{ preload_image_desktop | image_url: width: 750, format: 'avif' }} 750w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1100 -%}{{ preload_image_desktop | image_url: width: 1100, format: 'avif' }} 1100w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1200 -%}{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }} 1200w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  
    {% if preload_image_mobile != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(max-width: 767px)"
        href="{{ preload_image_mobile | image_url: width: 750, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_mobile.width >= 375 -%}{{ preload_image_mobile | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_mobile.width >= 550 -%}{{ preload_image_mobile | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_mobile.width >= 750 -%}{{ preload_image_mobile | image_url: width: 750, format: 'avif' }} 750w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  {%- elsif template.name == 'product' -%}
    {% assign preload_image_desktop = product.selected_or_first_available_variant.featured_image | default: product.featured_media.preview_image | default: product.media[0].preview_image | default: product.images[0] %}
    {% assign preload_image_mobile = preload_image_desktop %}
  
    {% if preload_image_desktop != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(min-width: 768px)"
        href="{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_desktop.width >= 375 -%}{{ preload_image_desktop | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_desktop.width >= 550 -%}{{ preload_image_desktop | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_desktop.width >= 750 -%}{{ preload_image_desktop | image_url: width: 750, format: 'avif' }} 750w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1100 -%}{{ preload_image_desktop | image_url: width: 1100, format: 'avif' }} 1100w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1200 -%}{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }} 1200w{%- endif -%}
        "
        imagesizes="50vw"
      >
    {% endif %}
  
    {% if preload_image_mobile != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(max-width: 767px)"
        href="{{ preload_image_mobile | image_url: width: 750, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_mobile.width >= 375 -%}{{ preload_image_mobile | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_mobile.width >= 550 -%}{{ preload_image_mobile | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_mobile.width >= 750 -%}{{ preload_image_mobile | image_url: width: 750, format: 'avif' }} 750w{%- endif -%}
        "
        imagesizes="80vw"
      >
    {% endif %}
  {%- elsif template.name == 'collection' -%}
    {% assign preload_image_desktop = collection.image | default: collection.products[0].featured_media.preview_image %}
    {% assign preload_image_mobile = preload_image_desktop %}
  
    {% if preload_image_desktop != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(min-width: 768px)"
        href="{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_desktop.width >= 375 -%}{{ preload_image_desktop | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_desktop.width >= 550 -%}{{ preload_image_desktop | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_desktop.width >= 750 -%}{{ preload_image_desktop | image_url: width: 750, format: 'avif' }} 750w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1100 -%}{{ preload_image_desktop | image_url: width: 1100, format: 'avif' }} 1100w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1200 -%}{{ preload_image_desktop | image_url: width: 1200, format: 'avif' }} 1200w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  
    {% if preload_image_mobile != blank %}
      <link
        rel="preload"
        as="image"
        type="image/avif"
        fetchpriority="high"
        media="(max-width: 767px)"
        href="{{ preload_image_mobile | image_url: width: 750, format: 'avif' }}"
        imagesrcset="
          {%- if preload_image_mobile.width >= 375 -%}{{ preload_image_mobile | image_url: width: 375, format: 'avif' }} 375w,{%- endif -%}
          {%- if preload_image_mobile.width >= 550 -%}{{ preload_image_mobile | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
          {%- if preload_image_mobile.width >= 750 -%}{{ preload_image_mobile | image_url: width: 750, format: 'avif' }} 750w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  {%- endif -%}
  
