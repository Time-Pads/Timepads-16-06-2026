{%- if request.page_type == 'index' -%}
    {% assign preload_image_desktop = settings.preload_image_desktop %}
    {% assign preload_image_mobile = settings.preload_image_mobile %}
  
    {% if preload_image_desktop != blank %}
      <link
        rel="preload"
        as="image"
        type="image/webp"
        fetchpriority="high"
        media="(min-width: 768px)"
        href="{{ preload_image_desktop | image_url: width: 1200, format: 'webp' }}"
        imagesrcset="
          {%- if preload_image_desktop.width >= 375 -%}{{ preload_image_desktop | image_url: width: 375, format: 'webp' }} 375w,{%- endif -%}
          {%- if preload_image_desktop.width >= 550 -%}{{ preload_image_desktop | image_url: width: 550, format: 'webp' }} 550w,{%- endif -%}
          {%- if preload_image_desktop.width >= 750 -%}{{ preload_image_desktop | image_url: width: 750, format: 'webp' }} 750w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1100 -%}{{ preload_image_desktop | image_url: width: 1100, format: 'webp' }} 1100w,{%- endif -%}
          {%- if preload_image_desktop.width >= 1200 -%}{{ preload_image_desktop | image_url: width: 1200, format: 'webp' }} 1200w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  
    {% if preload_image_mobile != blank %}
      <link
        rel="preload"
        as="image"
        type="image/webp"
        fetchpriority="high"
        media="(max-width: 767px)"
        href="{{ preload_image_mobile | image_url: width: 750, format: 'webp' }}"
        imagesrcset="
          {%- if preload_image_mobile.width >= 375 -%}{{ preload_image_mobile | image_url: width: 375, format: 'webp' }} 375w,{%- endif -%}
          {%- if preload_image_mobile.width >= 550 -%}{{ preload_image_mobile | image_url: width: 550, format: 'webp' }} 550w,{%- endif -%}
          {%- if preload_image_mobile.width >= 750 -%}{{ preload_image_mobile | image_url: width: 750, format: 'webp' }} 750w{%- endif -%}
        "
        imagesizes="100vw"
      >
    {% endif %}
  {%- elsif request.page_type == 'product' -%}
    {%- comment -%}
      LCP preload for product pages.
      The first image is rendered at width: 800 (desktop) / width: 400 (mobile)
      by media.liquid + image.liquid. The preload MUST match these exact URLs.
    {%- endcomment -%}
    {%- assign lcp_img = product.selected_or_first_available_variant.featured_image
                         | default: product.featured_media.preview_image
                         | default: product.media[0].preview_image
                         | default: product.images[0] -%}

    {%- if lcp_img != blank -%}
      {%- comment -%} Desktop preload: matches image.liquid srcset at 800w {%- endcomment -%}
      <link
        rel="preload"
        as="image"
        fetchpriority="high"
        media="(min-width: 768px)"
        href="{{ lcp_img | image_url: width: 800 }}"
        imagesrcset="{{ lcp_img | image_url: width: 400 }} 400w,
                     {{ lcp_img | image_url: width: 640 }} 640w,
                     {{ lcp_img | image_url: width: 800 }} 800w"
        imagesizes="(max-width: 768px) 100vw, 50vw"
      >
      {%- comment -%} Mobile preload: matches image.liquid srcset at 400w {%- endcomment -%}
      <link
        rel="preload"
        as="image"
        fetchpriority="high"
        media="(max-width: 767px)"
        href="{{ lcp_img | image_url: width: 400 }}"
        imagesrcset="{{ lcp_img | image_url: width: 300 }} 300w,
                     {{ lcp_img | image_url: width: 400 }} 400w,
                     {{ lcp_img | image_url: width: 640 }} 640w"
        imagesizes="100vw"
      >
    {%- endif -%}
  {%- elsif request.page_type == 'collection' -%}
    {%- comment -%} Collection LCP preload is handled directly in theme.liquid {%- endcomment -%}
  {%- endif -%}
