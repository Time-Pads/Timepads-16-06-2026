                  img-class: 'tw-w-full tw-max-h-[60rem]'
                %}
                  {% comment %} <img src="https://cdn.shopify.com/s/files/1/0845/7886/1371/files/free-delivery-and-free-shipping-icon-modern-design-template-free-vector.jpg?v=1738056496"/> {% endcomment %}
                </div> 
         
                {%  style %}
