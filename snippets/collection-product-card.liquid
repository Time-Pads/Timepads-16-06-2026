                                     data-variant-id-current="{{ variant_id }}"
                              >
                              <label class="button-for-open-quick-view" data-index="{{ forloop.index }}" data-target="{{ product.id }}">
                                  <span>{{ value }}</span>
                              </label>
                          </span>
                      </div>
                  {%- endfor -%}
              </div>
          {%- endfor -%}
      </div>
