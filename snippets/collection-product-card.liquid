            <dynamic-card class="quick-card">
              <div class="product-card" data-product-id="{{ product.id }}" data-variants="{{ product.variants | json }}">
                <div class="form__selectors">
                  <!-- Loop through each option (e.g., Size, Packs) -->
                  {% for option in product.options_with_values %}
                    <div class="selector-wrapper selector-wrapper--fullwidth js" data-select-label="{{ option.name }}" data-option-position="{{ forloop.index }}">
                      <fieldset class="radio__fieldset">
                        <legend class="radio__legend" aria-label="{{ option.name }}">
                          <span class="radio__legend__label">{{ option.name }}</span>
                        </legend>
                        <div class="radio__inputs">
                          <!-- Loop through values of the current option -->
                          {% for value in option.values %}
                            <span class="radio__button">
                              {% assign is_first = forloop.first %}
                              {% assign variant = product.variants | where: "option" | append: forloop.index | where: value | first %}
                              <input 
                                type="radio" 
                                name="{{ option.name }}-{{ product.id }}"
                                value="{{ value }}" 
                                id="{{ product.id }}-{{ option.name | handleize }}-{{ forloop.index }}" 
                                data-variant-id="{% if variant %}{{ variant.id }}{% endif %}" 
                                {% if is_first %} checked = checked {% endif %} 
                                class="variant-radio-input">     
                       
                              <label 
                                for="{{ product.id }}-{{ option.name | handleize }}-{{ forloop.index }}" 
                                class="variant-label aatemplate----{{ template }}">
                                <span>{{ value }}</span>
                              </label>
                   
                            </span>
                          {% endfor %}
                        </div>
                      </fieldset>
                    </div>
                  {% endfor %}
