   forloop: forloop,
   desktopImage: product.metafields.custom.shipping_free_are_not, 
   mobileImage: product.metafields.custom.shipping_free_are_not,
   img-class: 'tw-w-full tw-max-h-[60rem]'
   alt: 'period pad'
   %} {% endcomment %}
   <div class="free-shipping-text-product">
