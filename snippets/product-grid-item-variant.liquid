                        <input 
                        type="radio" 
                        name="{{ option.name }}-{{ product.id }}"
                        value="{{ value }}" 
                        id="{{ product.id }}-{{ option.name | handleize }}-{{ forloop.index }}" 
                        data-variant-id="{% if variant %}{{ variant.id }}{% endif %}" 
                        {% if is_first %} checked = checked {% endif %} 
                        class="variant-radio-input">  
                        <label 
                           for="{{ product.id }}-{{ option.name | handleize }}-{{ forloop.index }}" 
                           class="variant-label template----{{ template }}" style="background-color: #e3ced0; color: white">
                        <span>{{ value }}</span>
                        </label>
                        </span>
                        {% endfor %}
                     </div>
                  </fieldset>
               </div>
               {% endfor %}
            </div>
         </div>
         <noscript type="application/json">{{ product.variants | json }}</noscript>
      </div>
   </div>
   {%  style %} 
