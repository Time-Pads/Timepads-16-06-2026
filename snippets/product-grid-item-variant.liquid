    document.addEventListener('change', function (event) {
      var input = event.target.closest('.variant-radio-input');
      if (!input) return;

      var variantId = input.dataset.variantId;
      var container = input.closest('product-grid-item, product-grid-item-variant, .product-grid-item, .product-card');
      if (!variantId || !container) return;

      container.querySelectorAll("[name='id']").forEach(function (field) {
        field.value = variantId;
      });
    });
  }());
