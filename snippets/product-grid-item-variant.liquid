</button>



      {% endcapture %}

    <script>
      (function () {
        if (window.__tpCardDiscountInit) return;
        window.__tpCardDiscountInit = true;

        function updateDiscount(container) {
          if (!container) return;
          var discountBadge = container.querySelector('.product-discount-badge');
          var checkedInput = container.querySelector('.variant-radio-input:checked');
          if (!discountBadge || !checkedInput) return;

          var discount = checkedInput.getAttribute('data-discount');
          discountBadge.innerHTML = discount && parseFloat(discount) > 0 ? discount + '% OFF' : '';
        }

        function initDiscounts(root) {
          root.querySelectorAll('product-grid-item, product-grid-item-variant, .product-grid-item').forEach(function (container) {
            updateDiscount(container);
          });
        }

        document.addEventListener('change', function (event) {
          var input = event.target.closest('.variant-radio-input');
          if (!input) return;
          updateDiscount(input.closest('product-grid-item, product-grid-item-variant, .product-grid-item'));
        });

        function scheduleInit(root) {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(function () {
              initDiscounts(root);
            }, { timeout: 1500 });
            return;
          }
          window.setTimeout(function () {
            initDiscounts(root);
          }, 0);
        }

        if (document.readyState === 'complete') {
          scheduleInit(document);
        } else {
          window.addEventListener('load', function () {
            scheduleInit(document);
          }, { once: true });
        }
      }());
    </script>

