<!-- /snippets/social-meta-tags.liquid -->

{%- assign og_title = page_title | default: shop.name -%}
{%- assign og_url = canonical_url | default: shop.url -%}
{%- assign og_type = 'website' -%}
{%- assign og_description = page_description | default: shop.description | escape -%}

{%- assign default_image = 'https://timepads.in/cdn/shop/files/Untitled-11200.png?v=1741172243' -%}
{%- assign og_image = default_image -%}

{%- if template.name == 'product' and product.featured_media -%}
  {%- assign og_title = product.title | strip_html -%}
  {%- assign og_type = 'product' -%}
  {%- assign og_description = product.description | strip_html | truncatewords: 30 | escape -%}
  {%- assign og_image = product.featured_media.preview_image | img_url: '1200x628' -%}
{%- elsif template.name == 'article' and article.image -%}
  {%- assign og_title = article.title | strip_html -%}
  {%- assign og_type = 'article' -%}
  {%- assign og_description = article.excerpt_or_content | strip_html -%}
  {%- assign og_image = article.image | img_url: '1200x628' -%}
{%- elsif page_image -%}
  {%- assign og_image = page_image | img_url: '1200x628' -%}
{%- endif -%}

<!-- Open Graph (ONLY ONCE) -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description }}">
<meta property="og:image" content="https:{{ og_image }}">
<meta property="og:image:secure_url" content="https:{{ og_image }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="628">

<!-- Twitter (ONLY ONCE) -->
{% comment %} <meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@biowealproducts">
<meta name="twitter:title" content="{{ og_title }}">
<meta name="twitter:description" content="{{ og_description }}">
<meta name="twitter:image" content="https:{{ og_image }}"> {% endcomment %}