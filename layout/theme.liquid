  {%- comment -%}
    JS — all deferred. Loaded in dependency order.
  {%- endcomment -%}
  {% render 'quick-view-modal' %}
  <script>
    (function() {
      var loaded = false;
      var loading = false;
      function hasQuickViewCss() {
        var links = document.querySelectorAll('link[rel="stylesheet"]');
        for (var i = 0; i < links.length; i++) {
          if ((links[i].href || '').indexOf('quick-view.css') > -1) return true;
        }
        return false;
      }
      function hasQuickViewJs() {
        var scripts = document.querySelectorAll('script[src]');
        for (var i = 0; i < scripts.length; i++) {
          if ((scripts[i].src || '').indexOf('quick-view.js') > -1) return true;
        }
        return false;
      }
      function loadStyle(href) {
        return new Promise(function(resolve, reject) {
          var link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = href;
          link.onload = resolve;
          link.onerror = reject;
          document.head.appendChild(link);
        });
      }
      function loadScript(src) {
        return new Promise(function(resolve, reject) {
          var script = document.createElement('script');
          script.src = src;
          script.defer = true;
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }
      document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-qv-trigger]');
        if (!trigger) return;
        if (loaded || (hasQuickViewCss() && hasQuickViewJs())) {
          loaded = true;
          return;
        }
        event.preventDefault();
        event.stopPropagation();
        if (loading) return;
        loading = true;
        var promises = [];
        if (!hasQuickViewCss()) promises.push(loadStyle('{{ "quick-view.css" | asset_url }}'));
        if (!hasQuickViewJs()) promises.push(loadScript('{{ "quick-view.js" | asset_url }}'));
        Promise.all(promises).then(function() {
          loaded = true;
          loading = false;
          trigger.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
        }).catch(function() {
          loaded = true;
          loading = false;
          var handle = trigger.getAttribute('data-qv-handle');
          if (handle) {
            window.location.href = '/products/' + handle;
          }
        });
      }, true);
    })();
  </script>

